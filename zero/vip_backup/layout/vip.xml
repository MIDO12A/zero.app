<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:layout_gravity="center"
    android:orientation="vertical"
    android:tag="layout/dialog_zaky_vip_0"
    android:background="@drawable/shape_solid_rectangle_white_radius_17"
    android:paddingBottom="30pt"
    android:layout_width="348pt"
    android:layout_height="wrap_content">
    <com.shujiu.lib.view.roundlayout.RoundAngleRelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:topLeftRadius="18pt"
        app:topRightRadius="18pt">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="116pt"
            android:src="@drawable/img_popup_vip_title"
            android:scaleType="centerCrop"/>
        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="24pt"
            android:layout_height="24pt"
            android:layout_marginTop="18pt"
            android:src="@drawable/btn_popup_cancel"
            android:layout_marginEnd="18pt"
            android:layout_alignParentEnd="true"/>
    </com.shujiu.lib.view.roundlayout.RoundAngleRelativeLayout>
    <include
        android:id="@+id/common_zaky_star"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18pt"
        android:layout_marginEnd="18pt"
        layout="@layout/common_zaky_star"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/color_fff2b954"
        android:id="@+id/btn_more"
        android:padding="6pt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/k_more_1"/>
    <com.shujiu.lib.view.NineRecyclerView
        android:layout_gravity="center"
        android:id="@+id/recycler_sku"
        android:layout_width="match_parent"
        android:layout_height="110pt"
        android:layout_marginTop="12pt"
        android:layout_marginStart="24pt"
        android:layout_marginEnd="24pt"/>
</LinearLayout>

<!-- Content from fragment_zaky_vip.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:tag="layout/fragment_zaky_vip_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="172pt"
        android:src="@drawable/img_vip_title"
        android:scaleType="fitXY"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:orientation="vertical"
            android:tag="binding_1"
            android:paddingTop="20pt"
            android:paddingBottom="20pt"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32pt"
            android:layout_marginEnd="32pt">
            <include
                android:id="@+id/common_zaky_star"
                layout="@layout/common_zaky_star"/>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="142pt"
                android:layout_marginTop="12pt">
                <RelativeLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_width="0pt"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <View
                        android:background="@drawable/shape_solid_f7f7f7_24"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10pt"/>
                    <ImageView
                        android:id="@+id/iv_icon3"
                        android:layout_width="48pt"
                        android:layout_height="48pt"
                        android:src="@drawable/ico_vip_03name"
                        android:layout_centerHorizontal="true"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/color_fff2b954"
                        android:gravity="center"
                        android:id="@+id/tv_title3"
                        android:layout_width="140pt"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8pt"
                        android:text="@string/k_name_in_red"
                        android:layout_below="@+id/iv_icon3"
                        android:layout_centerHorizontal="true"/>
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_red_ff6d6d"
                        android:id="@+id/tv_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2pt"
                        android:layout_below="@+id/tv_title3"
                        android:layout_centerHorizontal="true"/>
                </RelativeLayout>
                <Space
                    android:layout_width="12pt"
                    android:layout_height="1pt"/>
                <RelativeLayout
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:layout_width="0pt"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <View
                        android:background="@drawable/shape_solid_f7f7f7_24"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="10pt"/>
                    <ImageView
                        android:id="@+id/iv_icon4"
                        android:layout_width="48pt"
                        android:layout_height="48pt"
                        android:src="@drawable/ico_vip_04coin"
                        android:layout_centerHorizontal="true"/>
                    <TextView
                        android:textSize="14sp"
                        android:textColor="@color/color_fff2b954"
                        android:gravity="center"
                        android:id="@+id/tv_title4"
                        android:layout_width="140pt"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8pt"
                        android:text="@string/k_coins_reward"
                        android:layout_below="@+id/iv_icon4"
                        android:layout_centerHorizontal="true"/>
                    <TextView
                        android:textSize="13sp"
                        android:textColor="@color/color_ff333333"
                        android:gravity="center"
                        android:id="@+id/tv_description4"
                        android:layout_width="110pt"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6pt"
                        android:text="@string/k_get_1500_coins"
                        android:includeFontPadding="false"
                        android:layout_below="@+id/tv_title4"
                        android:layout_centerHorizontal="true"/>
                </RelativeLayout>
            </LinearLayout>
            <com.shujiu.lib.view.NineRecyclerView
                android:layout_gravity="center"
                android:id="@+id/recycler_sku"
                android:layout_width="match_parent"
                android:layout_height="110pt"
                android:layout_marginTop="36pt"
                android:layout_marginBottom="20pt"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>

