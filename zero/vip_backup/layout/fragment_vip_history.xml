<?xml version="1.0" encoding="utf-8"?>
<com.shujiu.lib.view.refreshlayout.NineRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/refresh_layout"
    android:tag="layout/fragment_vip_history_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:orientation="vertical"
        android:id="@+id/rl_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/star_status"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="50pt"
            android:layout_marginTop="14pt"
            android:foreground="?attr/selectableItemBackground"
            android:layout_marginStart="15pt"
            android:layout_marginEnd="15pt"
            app:cardBackgroundColor="@color/color_fff3f4f5"
            app:cardCornerRadius="18pt"
            app:cardElevation="0pt">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="12pt"
                android:paddingEnd="12pt">
                <ImageView
                    android:id="@+id/iv_icon"
                    android:layout_width="28pt"
                    android:layout_height="28pt"
                    android:src="@drawable/icon_me_list_star_bl"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.AppTheme.Body"
                    android:textColor="?android:attr/textColorSecondary"
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/k_litchat_star"
                    android:layout_marginStart="10pt"/>
                <Space
                    android:layout_width="0pt"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
                <TextView
                    android:textAppearance="@style/TextAppearance.AppTheme.Body"
                    android:textColor="@color/color_ff333333"
                    android:gravity="end"
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/k_expired"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.shujiu.lib.view.NineRecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="12pt"
            android:layout_below="@+id/star_status"/>
    </RelativeLayout>
</com.shujiu.lib.view.refreshlayout.NineRefreshLayout>
