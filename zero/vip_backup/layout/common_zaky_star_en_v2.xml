<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:tag="layout/common_zaky_star_en_v2_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/shape_solid_f7f7f7_24"
        android:layout_width="match_parent"
        android:layout_height="82pt"
        android:paddingStart="20pt"
        android:paddingEnd="20pt">
        <ImageView
            android:layout_width="60pt"
            android:layout_height="60pt"
            android:src="@drawable/ico_vip_03name"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12pt">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_ff333333"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/k_name_appears_in_red"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/color_red_ff6d6d"
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2pt"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/shape_solid_f7f7f7_24"
        android:layout_width="match_parent"
        android:layout_height="82pt"
        android:layout_marginTop="10pt"
        android:paddingStart="20pt"
        android:paddingEnd="20pt">
        <ImageView
            android:layout_width="60pt"
            android:layout_height="60pt"
            android:src="@drawable/ico_vip_04coin"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_ff333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/k_500_coins_package_n_only_for_the_1st_purchase"
            android:layout_marginStart="12pt"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/shape_solid_f7f7f7_24"
        android:layout_width="match_parent"
        android:layout_height="82pt"
        android:layout_marginTop="10pt"
        android:paddingStart="20pt"
        android:paddingEnd="20pt">
        <ImageView
            android:layout_width="60pt"
            android:layout_height="60pt"
            android:src="@drawable/ico_vip_05visitor"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_ff333333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/k_to_view_your_visitor_list"
            android:layout_marginStart="12pt"/>
    </LinearLayout>
    <com.shujiu.lib.view.NineRecyclerView
        android:layout_gravity="center"
        android:id="@+id/recycler_sku"
        android:layout_width="match_parent"
        android:layout_height="110pt"
        android:layout_marginTop="40pt"/>
</LinearLayout>
