    android:layout_gravity="center"
    android:orientation="vertical"
    android:id="@+id/ll_container"
    android:tag="layout/item_vip_sku_0"
    android:background="@drawable/selector_stroke_f2f954_solid_f2f954_12dp"
    android:layout_width="match_parent"
    android:layout_height="110pt">
    <TextView
        android:textSize="16sp"
        android:textColor="@color/color_selector_333333_ffffff"
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <TextView
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/color_selector_ffd54f_ffffff"
        android:id="@+id/tv_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12pt"/>
</LinearLayout>
