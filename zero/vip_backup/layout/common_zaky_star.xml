<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="horizontal"
    android:tag="layout/common_zaky_star_0"
    android:layout_width="match_parent"
    android:layout_height="142pt"
    android:layout_marginTop="18pt">
    <RelativeLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="0pt"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <View
            android:background="@drawable/shape_solid_f7f7f7_24"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10pt"/>
        <ImageView
            android:id="@+id/iv_icon1"
            android:layout_width="48pt"
            android:layout_height="48pt"
            android:src="@drawable/ico_vip_01matches"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_fff2b954"
            android:gravity="center"
            android:id="@+id/tv_title1"
            android:layout_width="140pt"
            android:layout_height="wrap_content"
            android:layout_marginTop="2pt"
            android:text="@string/k_get_more_matches"
            android:layout_below="@+id/iv_icon1"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_ff333333"
            android:gravity="center"
            android:id="@+id/tv_description1"
            android:layout_width="110pt"
            android:layout_height="wrap_content"
            android:layout_marginTop="4pt"
            android:text="@string/k_more_crush_n_unlock_paper_plane_n_unlock_say_hi"
            android:includeFontPadding="false"
            android:layout_below="@+id/tv_title1"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
    <Space
        android:layout_width="12pt"
        android:layout_height="1pt"/>
    <RelativeLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="0pt"
        android:layout_height="142pt"
        android:layout_weight="1">
        <View
            android:background="@drawable/shape_solid_f7f7f7_24"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10pt"/>
        <ImageView
            android:id="@+id/iv_icon2"
            android:layout_width="48pt"
            android:layout_height="48pt"
            android:src="@drawable/ico_vip_02room"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_fff2b954"
            android:gravity="center"
            android:id="@+id/tv_title2"
            android:layout_width="140pt"
            android:layout_height="wrap_content"
            android:layout_marginTop="2pt"
            android:text="@string/k_privilege_for_room"
            android:layout_below="@+id/iv_icon2"
            android:layout_centerHorizontal="true"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/color_ff333333"
            android:gravity="center"
            android:id="@+id/tv_description2"
            android:layout_width="110pt"
            android:layout_height="wrap_content"
            android:layout_marginTop="4pt"
            android:text="@string/k_create_room_for_free_n_room_with_10_mics"
            android:includeFontPadding="false"
            android:layout_below="@+id/tv_title2"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
</LinearLayout>
