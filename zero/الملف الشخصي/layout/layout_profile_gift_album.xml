<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fl_gift_album"
    android:tag="layout/layout_profile_gift_album_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.shujiu.lib.view.NineSvgaView
        android:id="@+id/svga_decor_frame"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="282pt"/>
    <com.shujiu.lib.view.eva.NineEvaView
        android:id="@+id/eva_decor_frame"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="282pt"/>
    <ImageView
        android:id="@+id/iv_decor_frame"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="282pt"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_entry_group"
        android:background="@drawable/shape_primary_16pt_stroke_352d25"
        android:paddingBottom="16pt"
        android:layout_width="343pt"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/iv_bg_title"
            android:layout_width="243pt"
            android:layout_height="50pt"
            android:src="@drawable/tujian_profile_title_bg01"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/color_on_primary"
            android:id="@+id/tv_title_normal_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/k_badge_wall"
            app:layout_constraintBottom_toBottomOf="@+id/iv_bg_title"
            app:layout_constraintEnd_toEndOf="@+id/iv_bg_title"
            app:layout_constraintStart_toStartOf="@+id/iv_bg_title"
            app:layout_constraintTop_toTopOf="@+id/iv_bg_title"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/color_on_primary"
            android:id="@+id/tv_title_phy_mode"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/k_badge_wall"
            android:drawablePadding="4pt"
            android:drawableEnd="@drawable/ico_more02_white"
            app:layout_constraintBottom_toBottomOf="@+id/iv_bg_title"
            app:layout_constraintEnd_toEndOf="@+id/iv_bg_title"
            app:layout_constraintStart_toStartOf="@+id/iv_bg_title"
            app:layout_constraintTop_toTopOf="@+id/iv_bg_title"/>
        <ImageView
            android:id="@+id/btn_toggle_physical_mode"
            android:visibility="gone"
            android:layout_width="32pt"
            android:layout_height="32pt"
            android:layout_marginTop="18pt"
            android:src="@drawable/shape_selector_lock_unlock"
            android:layout_marginEnd="24pt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_content_normal_mode"
            android:layout_width="match_parent"
            android:layout_height="180pt"
            android:layout_marginTop="50pt"
            app:layout_constraintTop_toTopOf="parent">
            <com.shujiu.lib.view.NineRecyclerView
                android:id="@+id/rv_medals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.shujiu.zaky.biz.person.widget.phyitem.ProfileMedalsPhyView
            android:id="@+id/level_phy_view"
            android:visibility="gone"
            android:layout_width="297pt"
            android:layout_height="180pt"
            android:layout_marginTop="50pt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>
