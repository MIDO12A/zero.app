<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cl_center_content"
    android:tag="layout/layout_profile_content_new_0"
    android:clipChildren="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:layout_width="match_parent"
        android:layout_height="360pt"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.shujiu.zaky.module.widget.UserTagDanmakuView
        android:id="@+id/tagsDanmaku"
        android:layout_width="match_parent"
        android:layout_height="124pt"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.shujiu.zaky.module.cp2.api.widget.CpInfoView
        android:id="@+id/v_cp_info"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="82pt"
        android:layout_marginTop="126pt"
        android:layout_marginStart="16pt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.shujiu.lib.view.NineSvgaView
        android:id="@+id/v_vip"
        android:layout_width="80pt"
        android:layout_height="80pt"
        android:layout_marginTop="181pt"
        android:layout_marginEnd="16pt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_user_brief"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="216pt"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="24pt"
            android:layout_marginStart="16pt">
            <com.shujiu.zaky.module.widget.UserNameCombineView
                android:id="@+id/v_user_name_combine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <com.shujiu.zaky.module.widget.GenderView
                android:id="@+id/gender_view"
                android:layout_width="10pt"
                android:layout_height="10pt"
                android:layout_marginStart="4pt"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="24pt"
            android:layout_marginTop="8pt"
            android:layout_marginStart="16pt">
            <com.shujiu.lib.view.emoji.NineEmojiTextView
                android:textSize="16sp"
                android:id="@+id/profile_country"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <View
                android:background="@color/color_divider"
                android:layout_width="2pt"
                android:layout_height="12pt"
                android:layout_marginStart="12pt"
                android:layout_marginEnd="12pt"/>
            <com.shujiu.zaky.module.widget.UserIdView
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/color_on_primary"
                android:id="@+id/tv_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ImageView
                android:id="@+id/iv_id_copy"
                android:layout_width="20pt"
                android:layout_height="20pt"
                android:src="@drawable/icon_copy_20"
                android:layout_marginStart="4pt"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6pt"
            android:layout_marginStart="28pt"
            android:layout_marginEnd="28pt">
            <FrameLayout
                android:orientation="vertical"
                android:id="@+id/fl_followers_count"
                android:layout_width="70pt"
                android:layout_height="43pt">
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_ffffff"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tv_followers_count"
                    android:layout_width="wrap_content"
                    android:layout_height="27pt"
                    android:text="0"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/color_ccffffff"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="27pt"
                    android:layout_marginTop="21pt"
                    android:text="@string/k_followers"/>
            </FrameLayout>
            <Space
                android:layout_width="54pt"
                android:layout_height="1pt"/>
            <FrameLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/fl_followings_count"
                android:layout_width="70pt"
                android:layout_height="43pt">
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_ffffff"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tv_followings_count"
                    android:layout_width="wrap_content"
                    android:layout_height="27pt"
                    android:text="0"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/color_ccffffff"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="27pt"
                    android:layout_marginTop="21pt"
                    android:text="@string/k_following"/>
            </FrameLayout>
            <Space
                android:layout_width="54pt"
                android:layout_height="1pt"/>
            <FrameLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/fl_visitors_count"
                android:layout_width="70pt"
                android:layout_height="43pt">
                <TextView
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_ffffff"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:id="@+id/tv_visitors_count"
                    android:layout_width="wrap_content"
                    android:layout_height="27pt"
                    android:text="0"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="@color/color_ccffffff"
                    android:gravity="center"
                    android:layout_gravity="center_horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="27pt"
                    android:layout_marginTop="21pt"
                    android:text="@string/k_visitors"/>
            </FrameLayout>
        </LinearLayout>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10pt"
            android:layout_marginStart="12pt"
            android:layout_marginEnd="12pt">
            <Space
                android:id="@+id/medal_space_holder"
                android:layout_width="match_parent"
                android:layout_height="32pt"/>
            <com.shujiu.zaky.module.widget.UserMedalListView
                android:id="@+id/v_user_medal_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:medalExpandable="true"
                app:medalMaxLines="2"
                app:medalSize="32"/>
        </FrameLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ll_center_content"
        android:background="@color/color_background"
        android:paddingTop="16pt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16pt"
        android:paddingEnd="16pt"
        app:layout_constraintTop_toBottomOf="@+id/ll_user_brief">
        <TextView
            android:textAppearance="@style/TextAppearance.AppTheme.Body.14"
            android:textColor="@color/color_grey_999999"
            android:id="@+id/v_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <com.shujiu.zaky.module.widget.UserMedalListView
            android:id="@+id/v_user_medal_list_center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16pt"
            app:medalMaxLines="3"
            app:medalSize="20"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24pt">
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:orientation="horizontal"
                android:id="@+id/chatroom_layout"
                android:background="@drawable/shape_color_a56b15_8pt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="67pt"
                    android:layout_height="50pt">
                    <ImageView
                        android:id="@+id/iv_chat_room_cover"
                        android:tag="binding_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                    <ImageView
                        android:id="@+id/room_status_icon"
                        android:visibility="gone"
                        android:layout_width="25pt"
                        android:layout_height="25pt"
                        android:src="@drawable/ico_profile_inroom"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_on_primary"
                    android:ellipsize="end"
                    android:id="@+id/tv_room_name"
                    android:layout_width="0pt"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2pt"
                    android:layout_marginStart="12pt"
                    android:layout_marginEnd="12pt"/>
                <ImageView
                    android:layout_width="24pt"
                    android:layout_height="24pt"
                    android:src="@drawable/arrow_right_white"
                    android:layout_marginEnd="12pt"/>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/v_gift_album_fragment"
        android:background="@color/color_background"
        android:paddingTop="24pt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/ll_center_content"/>
    <com.shujiu.zaky.module.cp2.api.widget.CpProfileView
        android:id="@+id/v_cp_profile"
        android:background="@color/color_background"
        android:paddingTop="24pt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16pt"
        android:paddingEnd="16pt"
        app:layout_constraintTop_toBottomOf="@+id/v_gift_album_fragment"/>
</androidx.constraintlayout.widget.ConstraintLayout>
