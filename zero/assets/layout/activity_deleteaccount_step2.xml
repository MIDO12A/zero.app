<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.yuehai.p١١٣ui.widget.widget.StatusBarHeightImageView
        android:id="@+id/status_bar_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.yuehai.p١١٣ui.widget.widget.CommonTopBar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:top_bar_title="@string/DeleteAccount"/>
    <TextView
        android:textSize="@dimen/sp_17"
        android:textColor="#16151a"
        android:id="@+id/idTextContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_25"
        android:layout_marginBottom="@dimen/dp_10"
        android:text="@string/detailDeleteAccount2"
        android:layout_marginStart="@dimen/dp_15"
        android:layout_marginEnd="@dimen/dp_15"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idBarTitle"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idAccountBalanceIs0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_35"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idTextContent">
        <ImageView
            android:id="@+id/idImageViewA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/img_ask"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="#16151a"
            android:id="@+id/idTextTileA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/AccountBalanceIs0"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintStart_toEndOf="@+id/idImageViewA"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_83879A"
            android:id="@+id/idTextTipA"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/AccountBalanceIs0tip"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/idImageViewA"
            app:layout_constraintTop_toBottomOf="@+id/idTextTileA"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idBackpackIsEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_35"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idAccountBalanceIs0">
        <ImageView
            android:id="@+id/idImageViewB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/img_ask"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="#16151a"
            android:id="@+id/idTextTileB"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/BackpackIsEmpty"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintStart_toEndOf="@+id/idImageViewB"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_83879A"
            android:id="@+id/idTextTipB"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/BackpackIsEmptytip"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/idImageViewB"
            app:layout_constraintTop_toBottomOf="@+id/idTextTileB"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idNotAgency"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_35"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idBackpackIsEmpty">
        <ImageView
            android:id="@+id/idImageViewC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/img_ask"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="#16151a"
            android:id="@+id/idTextTileC"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/NotAgency"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintStart_toEndOf="@+id/idImageViewC"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_83879A"
            android:id="@+id/idTextTipC"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/NotAgencyTip"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/idImageViewC"
            app:layout_constraintTop_toBottomOf="@+id/idTextTileC"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idNotAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_35"
        android:layout_marginStart="@dimen/dp_10"
        android:layout_marginEnd="@dimen/dp_10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idNotAgency">
        <ImageView
            android:id="@+id/idImageViewD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/img_ask"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_18"
            android:textColor="#16151a"
            android:id="@+id/idTextTileD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/NotAdmin"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintStart_toEndOf="@+id/idImageViewD"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_83879A"
            android:id="@+id/idTextTipD"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:text="@string/NotAdminTip"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/idImageViewD"
            app:layout_constraintTop_toBottomOf="@+id/idTextTileD"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="@dimen/sp_17"
        android:textColor="@color/color_894916"
        android:gravity="center"
        android:id="@+id/idVerify"
        android:background="@drawable/shapea"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_45"
        android:layout_marginBottom="@dimen/dp_10"
        android:text="@string/clickToVerify"
        android:layout_marginStart="@dimen/dp_15"
        android:layout_marginEnd="@dimen/dp_15"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.appcompat.widget.LinearLayoutCompat>
