<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:background="@drawable/room_change_seat_bg"
        android:paddingTop="14dp"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/common_close_ic_2"
            android:paddingEnd="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/tv_seat_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/room_set_seat_style"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <RadioGroup
            android:orientation="horizontal"
            android:id="@+id/rb_seat_group"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="19dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="19dp"
            android:layout_marginHorizontal="19dp"
            android:paddingVertical="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_seat_title">
            <com.yuehai.p١١٣ui.widget.widget.radio.SquareRadioButton
                android:textSize="12sp"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/rb_seat_style_game"
                android:background="@drawable/room_seat_style_group_bg"
                android:paddingLeft="10dp"
                android:paddingTop="12dp"
                android:paddingRight="10dp"
                android:paddingBottom="12dp"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:checked="false"
                android:button="@null"
                android:minHeight="104dp"
                android:text="@string/room_seat_style_game"
                android:drawableTop="@mipmap/room_mic_seat_style_default_ic"
                android:drawablePadding="2dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="12dp"/>
            <com.yuehai.p١١٣ui.widget.widget.radio.SquareRadioButton
                android:textSize="12sp"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/rb_seat_style_normal"
                android:background="@drawable/room_seat_style_group_bg"
                android:paddingLeft="12dp"
                android:paddingTop="10dp"
                android:paddingRight="12dp"
                android:paddingBottom="10dp"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginLeft="6dp"
                android:layout_marginRight="6dp"
                android:checked="false"
                android:button="@null"
                android:minHeight="104dp"
                android:text="@string/room_seat_style_clasic"
                android:drawableTop="@mipmap/room_mic_seat_style_default_ic"
                android:drawablePadding="2dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="6dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"/>
            <com.yuehai.p١١٣ui.widget.widget.radio.SquareRadioButton
                android:textSize="12sp"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center"
                android:layout_gravity="center"
                android:id="@+id/rb_seat_style_vip"
                android:background="@drawable/room_seat_style_group_bg"
                android:paddingLeft="12dp"
                android:paddingTop="10dp"
                android:paddingRight="12dp"
                android:paddingBottom="10dp"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:checked="false"
                android:button="@null"
                android:minHeight="104dp"
                android:text="@string/room_seat_style_vip6"
                android:drawableTop="@mipmap/room_mic_seat_default_vip_2_ic"
                android:drawablePadding="2dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="10dp"/>
        </RadioGroup>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/number_seat_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/room_seat_style_number_seat_title"
            android:layout_marginStart="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rb_seat_group"/>
        <HorizontalScrollView
            android:id="@+id/horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="21dp"
            app:layout_constraintDimensionRatio="2:1"
            app:layout_constraintHeight_min="184dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/number_seat_title">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerview_seat_style"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toBottomOf="@+id/number_seat_title"/>
        </HorizontalScrollView>
        <androidx.appcompat.widget.AppCompatTextView
            android:textColor="@color/color_FFFFFF"
            android:gravity="center"
            android:id="@+id/tv_confirm"
            android:background="@drawable/btn_shape_confirm_12_bg"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="16dp"
            android:text="@string/room_set_confirm"
            android:layout_marginHorizontal="16dp"
            android:paddingVertical="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/horizontal"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:src="@mipmap/room_mic_seat_style_top_bg"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
