<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.yuehai.p١١٣ui.widget.text.YoopoTextView
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:gravity="bottom|center_horizontal"
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/btn_combo"
        android:background="@drawable/room_combo_btton_state"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:paddingBottom="22dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"
        android:layout_width="106dp"
        android:layout_height="57dp"
        android:layout_marginTop="6dp"
        android:text="1"
        android:paddingHorizontal="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_time"
        app:stroke_color="@color/color_FFBC0C1A"
        app:stroke_width="1dp"/>
    <com.yuehai.p١١٣ui.widget.widget.RoundedProgressBar
        android:layout_gravity="bottom"
        android:id="@+id/progress_bar"
        android:layout_width="0dp"
        android:layout_height="10dp"
        android:layout_marginStart="10dp"
        app:backgroundColor="@color/color_FFAE6208"
        app:borderColor="@color/color_FFFED315"
        app:borderWidth="2dp"
        app:cornerRadius="30dp"
        app:currentProgress="100"
        app:layout_constraintBottom_toBottomOf="@+id/iv_time"
        app:layout_constraintEnd_toEndOf="@+id/btn_combo"
        app:layout_constraintStart_toStartOf="@+id/btn_combo"
        app:layout_constraintTop_toTopOf="@+id/iv_time"
        app:maxProgress="100"
        app:progressColor="@color/color_FF3FD902"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_time"
        android:layout_width="20dp"
        android:layout_height="22dp"
        android:src="@mipmap/room_gift_combo_time_ic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
