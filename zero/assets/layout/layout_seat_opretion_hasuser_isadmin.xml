<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idPartA"
        android:background="@drawable/shape_white_juxing1"
        android:paddingBottom="@dimen/dp_15"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/idSeatActionUserDetail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_15"
            android:text="@string/idSeatActionUserDetail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <View
            android:id="@+id/idDriver1"
            android:background="@color/color_9BA1B6"
            android:layout_width="match_parent"
            android:layout_height="0.7dp"
            android:layout_marginTop="@dimen/dp_10"
            android:alpha="0.4"
            app:layout_constraintTop_toBottomOf="@+id/idSeatActionUserDetail"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/idSeatActionKickOffMic"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_20"
            android:text="@string/SeatActionKickOffMic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/idDriver1"/>
        <View
            android:id="@+id/idDriver2"
            android:background="@color/color_9BA1B6"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="0.7dp"
            android:layout_marginTop="@dimen/dp_10"
            android:alpha="0.4"
            app:layout_constraintTop_toBottomOf="@+id/idSeatActionKickOffMic"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/idSeatActionLockUnLockMic"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_15"
            android:text="@string/SeatActionLockMic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/idDriver2"/>
        <View
            android:id="@+id/idDriver3"
            android:background="@color/color_9BA1B6"
            android:layout_width="match_parent"
            android:layout_height="0.7dp"
            android:layout_marginTop="@dimen/dp_10"
            android:alpha="0.4"
            app:layout_constraintTop_toBottomOf="@+id/idSeatActionLockUnLockMic"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/idSeatActionComments"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_15"
            android:text="@string/idSeatActionAllowComments"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/idDriver3"/>
        <View
            android:id="@+id/idDriver5"
            android:background="@color/color_9BA1B6"
            android:layout_width="match_parent"
            android:layout_height="0.7dp"
            android:layout_marginTop="@dimen/dp_10"
            android:alpha="0.4"
            app:layout_constraintTop_toBottomOf="@+id/idSeatActionComments"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/idSeatActionBlackOrUnBlackUser"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_15"
            android:text="@string/SeatActionBlackUser"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/idDriver5"/>
        <View
            android:id="@+id/idDriver6"
            android:background="@color/color_9BA1B6"
            android:layout_width="match_parent"
            android:layout_height="0.7dp"
            android:layout_marginTop="@dimen/dp_10"
            android:alpha="0.4"
            app:layout_constraintTop_toBottomOf="@+id/idSeatActionBlackOrUnBlackUser"/>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textStyle="normal"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/idSeatActionKickOutFromRoom"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_25"
            android:layout_marginTop="@dimen/dp_15"
            android:text="@string/idSeatActionKickOut"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/idDriver6"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textStyle="normal"
        android:textColor="@color/black"
        android:gravity="center"
        android:id="@+id/idSeatActionCancel"
        android:background="@drawable/shape_white_juxing1"
        android:paddingTop="@dimen/dp_13"
        android:paddingBottom="@dimen/dp_13"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:text="@string/cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idPartA"/>
</androidx.constraintlayout.widget.ConstraintLayout>
