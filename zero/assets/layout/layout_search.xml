<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/layout_search_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idPartA"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/idBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_back_1"
            android:rotation="@integer/locale_mirror_flip"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.1"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_Search"
            android:background="@drawable/shape_search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/dp_10"
            app:layout_constraintStart_toEndOf="@+id/idBack"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.67">
            <ImageView
                android:id="@+id/idSeach"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:src="@mipmap/ic_search_gray"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.1"/>
            <EditText
                android:textSize="@dimen/sp_14"
                android:textColorHint="@color/color_D8D8D1"
                android:id="@+id/id_etText"
                android:background="@android:color/transparent"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:hint="@string/PleaseEnterId"
                android:maxLength="20"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintStart_toEndOf="@+id/idSeach"
                app:layout_constraintWidth_percent="0.65"/>
            <ImageView
                android:id="@+id/idClearSearch"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:src="@mipmap/ic_clear"
                android:layout_marginStart="@dimen/dp_5"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/id_etText"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.1"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/black"
            android:id="@+id/idTvSearch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_8"
            android:text="@string/Search"
            android:layout_marginStart="@dimen/dp_20"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/cl_Search"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.15"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idPartB"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_30"
        app:layout_constraintTop_toBottomOf="@+id/idPartA">
        <TextView
            android:textSize="@dimen/sp_16"
            android:textColor="@color/color_D8D8D1"
            android:id="@+id/idTvSearchTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_3"
            android:text="@string/SearchHistory"
            android:layout_marginStart="@dimen/dp_15"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <ImageView
            android:id="@+id/idClearHistoryIcon"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:src="@mipmap/ic_delet_gray"
            android:layout_marginEnd="@dimen/dp_5"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idSearchResult"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idPartB">
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/idTabLayout"
            android:paddingLeft="25dp"
            android:paddingRight="25dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent"
            app:tabIndicatorAnimationMode="elastic"
            app:tabIndicatorColor="@color/color_894916"
            app:tabIndicatorFullWidth="false"
            app:tabIndicatorHeight="1dp"
            app:tabSelectedTextColor="@color/color_894916"
            app:tabTextAppearance="@style/TabLayoutTextStyle"/>
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/id_ViewPager2"
            android:paddingTop="@dimen/dp_10"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/idTabLayout"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/idHistoryRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/dp_20"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idPartB"/>
</androidx.constraintlayout.widget.ConstraintLayout>
