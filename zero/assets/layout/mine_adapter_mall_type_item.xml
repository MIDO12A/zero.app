<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_item_bg"
        android:background="@drawable/mine_mall_item_nor_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_video_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:src="@mipmap/mine_mall_video_ic"
        app:layout_constraintBottom_toBottomOf="@+id/iv_item_bg"
        app:layout_constraintEnd_toEndOf="@+id/iv_item_bg"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_mall_img"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_item_bg"
        app:layout_constraintEnd_toEndOf="@+id/iv_item_bg"
        app:layout_constraintStart_toStartOf="@+id/iv_item_bg"
        app:layout_constraintTop_toTopOf="@+id/iv_item_bg"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="10sp"
        android:textColor="@color/color_FFFFE76C"
        android:gravity="center"
        android:id="@+id/tv_vip_discount_desc"
        android:background="@mipmap/mine_mall_discount_bg"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="@color/color_FAE9B5"
        android:ellipsize="end"
        android:id="@+id/tv_item_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:singleLine="true"
        app:layout_constraintStart_toStartOf="@+id/iv_item_bg"
        app:layout_constraintTop_toBottomOf="@+id/iv_item_bg"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="@color/color_FAE9B5"
        android:id="@+id/tv_gold_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:drawablePadding="2dp"
        app:drawableStartCompat="@mipmap/common_gold_ic_5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_item_name"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/color_FF887F67"
        android:id="@+id/tv_gold_origin_price"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/tv_gold_time"
        app:layout_constraintEnd_toEndOf="@+id/iv_item_bg"
        app:layout_constraintTop_toTopOf="@+id/tv_gold_time"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/color_FFFFFF"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_dress_up_state"
        android:background="@drawable/mine_package_dress_bg"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginTop="4dp"
        android:text="@string/mine_mall_package_dress_use"
        android:maxLines="1"
        android:layout_marginEnd="20dp"
        android:paddingHorizontal="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="65dp"
        app:layout_constraintWidth_min="49dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
