<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@mipmap/room_all_gift_normal_bg"
        android:scaleType="fitXY"
        android:minHeight="92dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_min="92dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="horizontal"
        android:id="@+id/ll_content_gift"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="60dp"
        android:layout_marginRight="60dp"
        android:layout_marginHorizontal="60dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_bg"
        app:layout_constraintStart_toStartOf="@+id/iv_bg"
        app:layout_constraintTop_toTopOf="@+id/iv_bg">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_avatar_send"
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:round_type="circle"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFEE15"
            android:id="@+id/tv_send_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAlignment="viewStart"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_send"
            app:layout_constraintStart_toEndOf="@+id/iv_avatar_send"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_send"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFFF"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@+id/tv_send_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/gift_name_send"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_send"
            app:layout_constraintStart_toEndOf="@+id/tv_send_name"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_send"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_avatar_receiver"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_send"
            app:layout_constraintStart_toEndOf="@+id/tv_send_label"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_send"
            app:round_type="circle"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFEE15"
            android:id="@+id/tv_receiver_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_marginStart="5dp"
            app:layout_constraintStart_toEndOf="@+id/iv_avatar_receiver"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_receiver"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/white"
            android:gravity="start"
            android:id="@+id/tv_gift_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
            app:layout_constraintStart_toStartOf="@+id/iv_avatar_send"
            app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_gift"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="7dp"
            app:layout_constraintStart_toEndOf="@+id/tv_gift_name"
            app:layout_constraintTop_toBottomOf="@+id/iv_avatar_send"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFE76C"
            android:id="@+id/tv_gift_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
            app:layout_constraintStart_toEndOf="@+id/iv_gift"
            app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
