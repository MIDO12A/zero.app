<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_transparent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_header_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@mipmap/rank_room_light_ic"
        android:translationY="-60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_third"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="63dp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cl_second"
        app:layout_constraintWidth_percent="0.3">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank_bg_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:src="@mipmap/rank_top_bg_2"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_2"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_rank_avatar_bg_2"
            app:layout_constraintEnd_toEndOf="@+id/iv_rank_avatar_bg_2"
            app:layout_constraintStart_toStartOf="@+id/iv_rank_avatar_bg_2"
            app:layout_constraintTop_toTopOf="@+id/iv_rank_avatar_bg_2"
            app:round_type="circle"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank_avatar_bg_2"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:src="@mipmap/rank_top_avatar_2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.widget.UserInfoView
            android:id="@+id/user_info_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_rank_avatar_bg_2"/>
        <com.yuehai.p١١٣ui.widget.widget.UserIdView
            android:id="@+id/user_id_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_info_2"/>
        <com.yuehai.p١١٣ui.widget.widget.RankLevelView
            android:id="@+id/rank_level_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_id_2"/>
        <com.yuehai.p١١٣ui.widget.widget.medal.UserMedalView
            android:id="@+id/rank_medal_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rank_level_2"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textColor="@color/color_FAE9B5"
            android:gravity="center_vertical"
            android:id="@+id/tv_gold_increase_2"
            android:background="@drawable/rank_gold_shape_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:drawableStart="@mipmap/common_gold_ic_8"
            android:drawableEnd="@mipmap/rank_gold_increase_ic"
            android:paddingHorizontal="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rank_medal_2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_second"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.48">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank_bg_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="60dp"
            android:src="@mipmap/rank_top_bg_1"
            android:scaleType="fitXY"
            app:layout_constraintDimensionRatio="1:1.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_rank_avatar_bg_1"
            app:layout_constraintEnd_toEndOf="@+id/iv_rank_avatar_bg_1"
            app:layout_constraintStart_toStartOf="@+id/iv_rank_avatar_bg_1"
            app:layout_constraintTop_toTopOf="@+id/iv_rank_avatar_bg_1"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank_avatar_bg_1"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:layout_marginTop="20dp"
            android:src="@mipmap/rank_top_avatar_1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.widget.UserInfoView
            android:id="@+id/user_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_rank_avatar_bg_1"/>
        <com.yuehai.p١١٣ui.widget.widget.UserIdView
            android:id="@+id/user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_info"/>
        <com.yuehai.p١١٣ui.widget.widget.RankLevelView
            android:id="@+id/rank_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_id"/>
        <com.yuehai.p١١٣ui.widget.widget.medal.UserMedalView
            android:id="@+id/rank_medal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginStart="15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rank_level"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textColor="@color/color_FAE9B5"
            android:gravity="center_vertical"
            android:id="@+id/tv_gold_increase"
            android:background="@drawable/rank_gold_shape_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:drawableStart="@mipmap/common_gold_ic_8"
            android:drawableEnd="@mipmap/rank_gold_increase_ic"
            android:paddingHorizontal="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rank_medal"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_four"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="63dp"
        android:layout_marginStart="-20dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/cl_second"
        app:layout_constraintWidth_percent="0.3">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank_bg_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:src="@mipmap/rank_top_bg_3"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_3"
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_rank_avatar_bg_3"
            app:layout_constraintEnd_toEndOf="@+id/iv_rank_avatar_bg_3"
            app:layout_constraintStart_toStartOf="@+id/iv_rank_avatar_bg_3"
            app:layout_constraintTop_toTopOf="@+id/iv_rank_avatar_bg_3"
            app:round_type="circle"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rank_avatar_bg_3"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:src="@mipmap/rank_top_avatar_3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.widget.UserInfoView
            android:id="@+id/user_info_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/iv_rank_avatar_bg_3"/>
        <com.yuehai.p١١٣ui.widget.widget.UserIdView
            android:id="@+id/user_id_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_info_3"/>
        <com.yuehai.p١١٣ui.widget.widget.RankLevelView
            android:id="@+id/rank_level_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_id_3"/>
        <com.yuehai.p١١٣ui.widget.widget.medal.UserMedalView
            android:id="@+id/rank_medal_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rank_level_3"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FAE9B5"
            android:gravity="center_vertical"
            android:id="@+id/tv_gold_increase_3"
            android:background="@drawable/rank_gold_shape_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:layout_marginTop="5dp"
            android:drawableStart="@mipmap/common_gold_ic_8"
            android:drawableEnd="@mipmap/rank_gold_increase_ic"
            android:paddingHorizontal="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rank_medal_3"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
