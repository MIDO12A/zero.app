<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_rank_item_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:src="@mipmap/union_rank_1_bg"
        android:scaleType="fitXY"
        android:layout_marginHorizontal="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_rank_num_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/union_rank_1_num_bg"
        android:scaleType="fitXY"
        android:rotationY="@integer/locale_mirror_flip"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@+id/iv_rank_item_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.3"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_rank_label_ic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/union_rank_label_1_ic"
        app:layout_constraintEnd_toEndOf="@+id/iv_rank_num_bg"
        app:layout_constraintStart_toStartOf="@+id/iv_rank_num_bg"
        app:layout_constraintTop_toTopOf="@+id/iv_rank_num_bg"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="24sp"
        android:textColor="@color/color_FFFFFF"
        android:id="@+id/tv_rank_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/iv_rank_num_bg"
        app:layout_constraintEnd_toEndOf="@+id/iv_rank_num_bg"
        app:layout_constraintStart_toStartOf="@+id/iv_rank_num_bg"
        app:layout_constraintTop_toTopOf="@+id/iv_rank_num_bg"/>
    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
        android:id="@+id/iv_union_avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginVertical="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_rank_num_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:round_border_color="@color/color_FFFEEC93"
        app:round_border_width="1dp"
        app:round_corner_radius="8dp"
        app:round_type="round"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_union_avatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_union_avatar"
        app:layout_constraintTop_toTopOf="@+id/iv_union_avatar">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="14sp"
            android:textColor="@color/color_FFFFFF"
            android:ellipsize="end"
            android:id="@+id/tv_union_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/tv_member_count"
            android:background="@drawable/union_member_count_bg"
            android:paddingLeft="6dp"
            android:paddingTop="1dp"
            android:paddingRight="6dp"
            android:paddingBottom="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawablePadding="4dp"
            android:drawableStart="@mipmap/union_member_count_ic"
            android:paddingHorizontal="6dp"
            android:paddingVertical="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_union_name"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_80ffffff"
            android:id="@+id/tv_union_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_member_count"
            app:layout_constraintStart_toEndOf="@+id/tv_member_count"
            app:layout_constraintTop_toTopOf="@+id/tv_member_count"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
