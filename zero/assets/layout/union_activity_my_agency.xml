<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_1A1A1A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appbar_layout"
            android:background="@color/color_transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="snap|enterAlways|scroll">
            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_scrollFlags="exitUntilCollapsed|scroll">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:src="@mipmap/union_my_agency_bg"
                        android:scaleType="centerCrop"
                        android:minWidth="146dp"
                        android:minHeight="182dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_avatar_bg"
                        android:layout_width="146dp"
                        android:layout_height="182dp"
                        android:layout_marginTop="110dp"
                        android:src="@mipmap/union_my_agency_avatar_bg"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_invite"
                        android:background="@mipmap/union_sub_agent_invite_bg"
                        android:paddingLeft="6dp"
                        android:paddingTop="3dp"
                        android:paddingRight="6dp"
                        android:paddingBottom="3dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="200dp"
                        android:layout_marginBottom="15dp"
                        android:elevation="10dp"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="3dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_invite_ic"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@mipmap/union_sub_agent_invite_ic"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="11sp"
                            android:textColor="@color/color_FFFFFF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/union_sub_agent_invite_title"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iv_invite_ic"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
                        android:id="@+id/iv_agency_avatar"
                        android:layout_width="98dp"
                        android:layout_height="98dp"
                        app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_bg"
                        app:layout_constraintEnd_toEndOf="@+id/iv_avatar_bg"
                        app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"
                        app:layout_constraintTop_toTopOf="@+id/iv_avatar_bg"
                        app:round_corner_radius="20dp"
                        app:round_type="round"/>
                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_rank_crown"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="-12dp"
                        android:src="@mipmap/union_agency_avatar_heder_ic"
                        android:outlineProvider="background"
                        app:layout_constraintBottom_toTopOf="@+id/iv_agency_avatar"
                        app:layout_constraintEnd_toEndOf="@+id/iv_agency_avatar"
                        app:layout_constraintStart_toStartOf="@+id/iv_agency_avatar"/>
                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_agency_border_avatar"
                        android:layout_width="98dp"
                        android:layout_height="98dp"
                        android:src="@mipmap/union_avatar_border_ic"
                        app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_bg"
                        app:layout_constraintEnd_toEndOf="@+id/iv_avatar_bg"
                        app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"
                        app:layout_constraintTop_toTopOf="@+id/iv_avatar_bg"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/ll_agency_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_avatar_bg">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_agency_country"
                            android:layout_width="20dp"
                            android:layout_height="13dp"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="15sp"
                            android:textColor="@color/color_FFFFFF"
                            android:id="@+id/tv_agency_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            app:fontFamily="sans-serif-medium"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="12sp"
                        android:textColor="@color/color_80ffffff"
                        android:id="@+id/tv_agency_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:drawableStart="@mipmap/union_id_ic"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/ll_agency_name"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/cl_rank_detail"
                        android:background="@drawable/union_agency_info_bg"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginRight="16dp"
                        android:layout_marginHorizontal="16dp"
                        android:paddingVertical="10dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintHeight_min="56dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_agency_id">
                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:id="@+id/cl_rank"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintWidth_percent="0.33">
                            <androidx.appcompat.widget.AppCompatTextView
                                android:textSize="12sp"
                                android:textColor="@color/color_FFFFF5AD"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/union_rank_title"
                                android:drawablePadding="4dp"
                                android:drawableStart="@mipmap/union_agency_rank_1_ic"/>
                            <androidx.appcompat.widget.AppCompatTextView
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_FFFFF5AD"
                                android:id="@+id/tv_rank_num"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/union_rank_data"/>
                        </androidx.appcompat.widget.LinearLayoutCompat>
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:id="@+id/cl_member"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:layout_constraintStart_toEndOf="@+id/cl_rank"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintWidth_percent="0.33">
                            <androidx.appcompat.widget.AppCompatTextView
                                android:textSize="12sp"
                                android:textColor="@color/color_FFFFF5AD"
                                android:id="@+id/tv_member_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/union_member_title"
                                android:drawablePadding="4dp"
                                android:drawableStart="@mipmap/union_agency_member_ic"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>
                            <androidx.appcompat.widget.AppCompatTextView
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_FFFFF5AD"
                                android:id="@+id/tv_member_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="0"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/tv_member_title"/>
                            <View
                                android:background="@color/color_4dffffff"
                                android:layout_width="0.5dp"
                                android:layout_height="0dp"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:layout_marginVertical="10dp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:gravity="center_horizontal"
                            android:orientation="vertical"
                            android:id="@+id/cl_sub_agent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintWidth_percent="0.33">
                            <androidx.appcompat.widget.AppCompatTextView
                                android:textSize="12sp"
                                android:textColor="@color/color_FFFFF5AD"
                                android:id="@+id/tv_sub_agent_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/union_sub_agent_title_2"
                                android:drawablePadding="4dp"
                                android:drawableStart="@mipmap/union_sub_agent_ic"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>
                            <androidx.appcompat.widget.AppCompatTextView
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_FFFFF5AD"
                                android:id="@+id/tv_sub_agent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/union_rank_data"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@+id/tv_sub_agent_title"/>
                            <View
                                android:background="@color/color_4dffffff"
                                android:layout_width="0.5dp"
                                android:layout_height="0dp"
                                android:layout_marginTop="10dp"
                                android:layout_marginBottom="10dp"
                                android:layout_marginVertical="10dp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"/>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_notice"
                        android:background="@drawable/union_agency_info_bg"
                        android:paddingLeft="12dp"
                        android:paddingTop="10dp"
                        android:paddingRight="12dp"
                        android:paddingBottom="10dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="16dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="16dp"
                        android:layout_marginHorizontal="16dp"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/cl_rank_detail">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="13sp"
                            android:textColor="@color/color_FFFFFF"
                            android:id="@+id/tv_notice_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/union_notice_title"
                            android:drawablePadding="5dp"
                            android:drawableStart="@mipmap/union_notice_ic"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@mipmap/common_next_5"
                            android:rotation="@integer/locale_mirror_flip"
                            app:layout_constraintBottom_toBottomOf="@+id/tv_notice_title"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/tv_notice_title"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="12sp"
                            android:textColor="@color/color_FFFFFF"
                            android:ellipsize="end"
                            android:id="@+id/tv_notice_content"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:maxLines="2"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/tv_notice_title"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <View
                        android:background="@color/color_transparent"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        app:layout_constraintTop_toBottomOf="@+id/cl_notice"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.appcompat.widget.Toolbar
                    android:paddingBottom="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:contentInsetStart="0dp"
                    app:contentInsetStartWithNavigation="0dp"
                    app:layout_collapseMode="pin">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.yuehai.p١١٣ui.widget.widget.StatusBarHeightImageView
                            android:id="@+id/status_bar_height"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_back"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@mipmap/back_white_2"
                            android:rotationY="@integer/locale_mirror_flip"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/status_bar_height"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="17sp"
                            android:textColor="@color/color_FFFFFF"
                            android:id="@+id/tv_agency_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/union_my_agency_title"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/status_bar_height"/>
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_edit"
                            android:visibility="gone"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@mipmap/union_edit_ic"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/status_bar_height"/>
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_union_rule"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@mipmap/union_rule_ic"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/iv_edit"
                            app:layout_constraintTop_toBottomOf="@+id/status_bar_height"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.appcompat.widget.Toolbar>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_tab"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-10dp"
                app:layout_collapseMode="pin">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@mipmap/union_tab_bg"
                    android:scaleType="fitXY"
                    android:minHeight="20dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/union_tab"
                    android:background="@color/color_transparent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_scrollFlags="snap|enterAlways"
                    app:tabMode="scrollable"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="2dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
