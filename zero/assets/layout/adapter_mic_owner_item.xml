<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintEnd_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">
    <com.opensource.svgaplayer.SVGAImageView
        android:id="@+id/svga_speaker_wave"
        android:layout_width="172dp"
        android:layout_height="172dp"
        android:scaleType="fitXY"
        app:clearsAfterDetached="true"
        app:clearsAfterStop="true"
        app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
        app:layout_constraintEnd_toEndOf="@+id/iv_avatar"
        app:layout_constraintStart_toStartOf="@+id/iv_avatar"
        app:layout_constraintTop_toTopOf="@+id/iv_avatar"
        app:loopCount="1"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_avatar"
        android:layout_width="104dp"
        android:layout_height="104dp"
        android:src="@mipmap/room_mic_seat_default_ic"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.opensource.svgaplayer.SVGAImageView
        android:id="@+id/svga_avatar_header"
        android:layout_width="111dp"
        android:layout_height="111dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_avatar"
        app:layout_constraintEnd_toEndOf="@+id/iv_avatar"
        app:layout_constraintStart_toStartOf="@+id/iv_avatar"
        app:layout_constraintTop_toTopOf="@+id/iv_avatar"
        app:loopCount="-1"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textColor="@color/color_FFFFFF"
        android:gravity="center_horizontal"
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="@+id/svga_avatar_header"
        app:layout_constraintStart_toStartOf="@+id/svga_avatar_header"
        app:layout_constraintTop_toBottomOf="@+id/svga_avatar_header"/>
</androidx.constraintlayout.widget.ConstraintLayout>
