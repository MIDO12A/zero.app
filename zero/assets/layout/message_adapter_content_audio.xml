<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:id="@+id/audio_content_ll"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_centerVertical="true">
    <TextView
        android:textSize="14.5sp"
        android:textColor="#000000"
        android:layout_gravity="center_vertical"
        android:id="@+id/audio_time_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textDirection="ltr"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="5dp"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/audio_play_iv"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/chat_voice_msg_playing_3"
        android:scaleType="centerCrop"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"/>
    <com.tencent.qcloud.tuikit.timcommon.component.UnreadCountTextView
        android:id="@+id/audio_unread_voice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"/>
</LinearLayout>
