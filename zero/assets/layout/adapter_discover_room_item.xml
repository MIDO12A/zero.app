<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
        android:id="@+id/iv_room_logo"
        android:background="@mipmap/discover_game_teaming_ic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:round_corner_radius="8dp"
        app:round_type="round"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@mipmap/discover_room_item_info_bg"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_percent="0.3"
            app:layout_constraintStart_toStartOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_room_rank_ic"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@mipmap/discover_room_item_1"
            android:scaleType="fitCenter"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/discover_item_hot_bg"
            android:paddingLeft="2dp"
            android:paddingTop="1dp"
            android:paddingRight="2dp"
            android:paddingBottom="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:paddingHorizontal="2dp"
            android:paddingVertical="1dp"
            app:layout_constraintEnd_toEndOf="@+id/iv_room_rank_ic"
            app:layout_constraintTop_toTopOf="@+id/iv_room_rank_ic">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_num_gif"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/color_FFFFE76C"
                android:id="@+id/tv_online_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_user_avatar"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="2dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_country_logo"
                android:layout_width="20dp"
                android:layout_height="12dp"
                android:layout_marginBottom="12dp"
                android:scaleType="fitXY"
                android:layout_marginStart="13dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/color_FFFFFF"
                android:id="@+id/tv_room_hot_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="13dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_country_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@+id/iv_country_logo"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_hot_logo"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@mipmap/room_hot_logo_ic"
                android:layout_marginEnd="2dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_country_logo"
                app:layout_constraintEnd_toStartOf="@+id/tv_room_hot_value"
                app:layout_constraintTop_toTopOf="@+id/iv_country_logo"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="14sp"
                android:textColor="@color/color_FFFFFF"
                android:ellipsize="end"
                android:gravity="start|center_vertical"
                android:id="@+id/tv_room_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp"
                android:maxLines="1"
                android:layout_marginHorizontal="4dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_country_logo"
                app:layout_constraintEnd_toStartOf="@+id/iv_hot_logo"
                app:layout_constraintStart_toEndOf="@+id/iv_country_logo"
                app:layout_constraintTop_toTopOf="@+id/iv_country_logo"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="11sp"
                android:textColor="@color/color_FFFFFF"
                android:id="@+id/tv_room_type"
                android:paddingLeft="6dp"
                android:paddingTop="2dp"
                android:paddingRight="6dp"
                android:paddingBottom="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                app:layout_constraintBottom_toTopOf="@+id/iv_country_logo"
                app:layout_constraintStart_toStartOf="@+id/iv_country_logo"/>
            <Space
                android:layout_width="match_parent"
                android:layout_height="8dp"
                app:layout_constraintBottom_toTopOf="@+id/tv_room_type"
                app:layout_constraintStart_toStartOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
