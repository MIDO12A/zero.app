<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_header_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:src="@mipmap/union_my_agency_bg"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/cl_guild_user_info">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="150dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="15sp"
                android:textColor="@color/color_FFFFFF"
                android:id="@+id/tv_rank_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="105dp"
                android:text="@string/union_last_week_rank_title"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="44sp"
                android:textStyle="bold"
                android:textColor="@color/color_FFFFF5AD"
                android:gravity="center"
                android:id="@+id/tv_rank_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:drawablePadding="12dp"
                android:drawableStart="@mipmap/union_rank_top_ic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_rank_title"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-60dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_rank_top">
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_bg"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="fitXY"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintDimensionRatio="1:1.267"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_rank_crown"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="-12dp"
                    android:src="@mipmap/union_agency_avatar_heder_ic"
                    android:outlineProvider="background"
                    app:layout_constraintBottom_toTopOf="@+id/iv_avatar_bg"
                    app:layout_constraintEnd_toEndOf="@+id/iv_avatar_bg"
                    app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_avatar_bg"
                    android:layout_width="129dp"
                    android:layout_height="129dp"
                    android:layout_marginTop="131dp"
                    android:src="@mipmap/union_avatar_border_ic"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="117dp"
                    android:layout_height="117dp"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_bg"
                    app:layout_constraintEnd_toEndOf="@+id/iv_avatar_bg"
                    app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toTopOf="@+id/iv_avatar_bg"
                    app:round_corner_radius="17dp"
                    app:round_type="round"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="15sp"
                    android:textColor="@color/color_FFFFFF"
                    android:ellipsize="end"
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:maxLines="1"
                    android:maxLength="20"
                    app:layout_constraintEnd_toEndOf="@+id/iv_bg"
                    app:layout_constraintStart_toStartOf="@+id/iv_bg"
                    app:layout_constraintTop_toBottomOf="@+id/iv_avatar_bg"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_country"
                    android:layout_width="20dp"
                    android:layout_height="12dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintEnd_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toBottomOf="@+id/tv_name"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="13sp"
                    android:textColor="@color/color_FFFFF5AD"
                    android:ellipsize="end"
                    android:id="@+id/tv_country_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_marginStart="16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_country"
                    app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toTopOf="@+id/iv_country"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_member_ic"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="8dp"
                    android:src="@mipmap/union_info_member_ic"
                    app:layout_constraintEnd_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toBottomOf="@+id/iv_country"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="13sp"
                    android:textColor="@color/color_FFFFF5AD"
                    android:ellipsize="end"
                    android:id="@+id/tv_member_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_marginStart="16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_member_ic"
                    app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toTopOf="@+id/iv_member_ic"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_id_ic"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="8dp"
                    android:src="@mipmap/union_info_id_ic"
                    app:layout_constraintEnd_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toBottomOf="@+id/iv_member_ic"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="13sp"
                    android:textColor="@color/color_FFFFF5AD"
                    android:ellipsize="end"
                    android:id="@+id/tv_member_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:layout_marginStart="16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_id_ic"
                    app:layout_constraintStart_toStartOf="@+id/iv_avatar_bg"
                    app:layout_constraintTop_toTopOf="@+id/iv_id_ic"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
    <com.yuehai.p١١٣ui.widget.widget.StatusBarHeightImageView
        android:id="@+id/status_bar_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/status_bar_height">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@mipmap/back_white_2"
            android:rotationY="@integer/locale_mirror_flip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/union_detail_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/cl_guild_user_info"
        android:background="@color/color_1A1A1A"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@mipmap/union_tab_bg"
            android:scaleType="fitXY"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_user_info"
            android:paddingLeft="16dp"
            android:paddingTop="21dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="16dp"
            app:layout_constraintBottom_toTopOf="@+id/tv_confirm"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_user_avatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/iv_user_avatar"
                app:layout_constraintTop_toTopOf="parent">
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_user_country"
                    android:layout_width="20dp"
                    android:layout_height="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="14sp"
                    android:textColor="@color/color_FFFFFF"
                    android:ellipsize="end"
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:maxLength="20"
                    android:layout_marginStart="4dp"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_user_country"
                    app:layout_constraintEnd_toStartOf="@+id/iv_user_sex"
                    app:layout_constraintHorizontal_weight="1"
                    app:layout_constraintStart_toEndOf="@+id/iv_user_country"
                    app:layout_constraintTop_toTopOf="@+id/iv_user_country"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_user_sex"
                    android:layout_width="18dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="4dp"
                    app:layout_constraintStart_toEndOf="@+id/tv_user_name"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <com.yuehai.p١١٣ui.widget.widget.UserIdView
                android:id="@+id/user_id_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="-4dp"
                app:layout_constraintStart_toStartOf="@+id/cl_info"
                app:layout_constraintTop_toBottomOf="@+id/cl_info"/>
            <com.yuehai.p١١٣ui.widget.widget.RankLevelView
                android:id="@+id/user_level_view"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/iv_agent_ic"
                app:layout_constraintTop_toTopOf="@+id/iv_agent_ic"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_agent_ic"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:src="@mipmap/union_ic"
                app:layout_constraintStart_toStartOf="@+id/user_id_view"
                app:layout_constraintTop_toBottomOf="@+id/user_id_view"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.AppCompatTextView
            android:textColor="@color/color_FF59370D"
            android:gravity="center"
            android:id="@+id/tv_confirm"
            android:background="@drawable/union_btn_pre_bg"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginBottom="21dp"
            android:text="@string/union_apply_title"
            android:layout_marginHorizontal="16dp"
            android:paddingVertical="14dp"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
