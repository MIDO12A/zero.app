<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="16dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="15sp"
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/tv_room_title"
            android:paddingBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/room_card_info_title"
            android:fontFamily="sans-serif-medium"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@mipmap/room_owner_info_room_bg"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
                android:id="@+id/iv_room_avatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:round_corner_radius="8dp"
                app:round_type="round"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="16sp"
                android:textColor="@color/color_FFFFFF"
                android:id="@+id/tv_room_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toEndOf="@+id/iv_room_avatar"
                app:layout_constraintTop_toTopOf="@+id/iv_room_avatar"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_room_country"
                android:layout_width="20dp"
                android:layout_height="13dp"
                android:layout_marginStart="5dp"
                app:layout_constraintBottom_toBottomOf="@+id/tv_room_name"
                app:layout_constraintStart_toEndOf="@+id/tv_room_name"
                app:layout_constraintTop_toTopOf="@+id/tv_room_name"/>
            <com.yuehai.p١١٣ui.widget.widget.UserIdView
                android:id="@+id/room_id_view"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="-5dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_room_avatar"
                app:layout_constraintStart_toStartOf="@+id/tv_room_name"
                app:layout_constraintTop_toTopOf="@+id/iv_room_avatar"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="9sp"
                android:textColor="@color/color_FFFFFF"
                android:id="@+id/tv_room_type"
                android:background="@drawable/room_header_type_bg_1"
                android:paddingLeft="6dp"
                android:paddingTop="1dp"
                android:paddingRight="6dp"
                android:paddingBottom="1dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:paddingHorizontal="6dp"
                android:paddingVertical="1dp"
                app:layout_constraintBottom_toBottomOf="@+id/iv_room_avatar"
                app:layout_constraintStart_toStartOf="@+id/tv_room_name"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_room_report"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginBottom="6dp"
                android:src="@mipmap/room_report_room_ic"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_room_edit"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginBottom="6dp"
                android:src="@mipmap/room_edit_room_ic"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="15sp"
            android:textColor="@color/color_FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/room_owner_title"
            android:fontFamily="sans-serif-medium"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">
            <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
                android:id="@+id/iv_avatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:round_type="circle"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp">
                <com.yuehai.p١١٣ui.widget.widget.UserInfoView
                    android:id="@+id/user_info_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.yuehai.p١١٣ui.widget.widget.UserIdView
                    android:id="@+id/user_id_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:layout_marginStart="-5dp"
                    app:layout_constraintStart_toStartOf="parent"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="15sp"
            android:textColor="@color/color_FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/room_owner_notice_title"
            android:fontFamily="sans-serif-medium"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="13sp"
            android:textColor="@color/color_FFFFFF"
            android:gravity="start|top"
            android:id="@+id/tv_notice"
            android:background="@drawable/room_notice_bg"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="105dp"/>
        <androidx.appcompat.widget.LinearLayoutCompat
            android:gravity="center"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:id="@+id/ll_follow"
            android:background="@drawable/btn_shape_confirm_12_bg"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_follow_state"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/room_follow_pre"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="15sp"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center"
                android:layout_gravity="bottom"
                android:id="@+id/tv_confirm"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="@string/room_user_follow"
                android:layout_marginStart="5dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.core.widget.NestedScrollView>
