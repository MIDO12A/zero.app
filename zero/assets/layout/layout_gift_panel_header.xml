<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingLeft="14dp"
    android:paddingTop="6dp"
    android:paddingRight="14dp"
    android:paddingBottom="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="14dp">
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="10sp"
        android:textColor="@color/color_FFFFFF"
        android:id="@+id/tv_send_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/room_gift_send_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/color_FFFFFF"
        android:gravity="center"
        android:id="@+id/tv_select_all"
        android:background="@mipmap/room_gift_all_select_nor"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:text="@string/room_gift_All_label"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview_mic_user"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_marginEnd="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/tv_select_all"
        app:layout_constraintStart_toEndOf="@+id/tv_send_label"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
