<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="8dp"
    android:layout_marginTop="16dp"
    android:layout_marginRight="8dp"
    android:layout_marginHorizontal="8dp">
    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
        android:id="@+id/iv_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:round_corner_radius="8dp"
        app:round_type="round"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_bg_color"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.8"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
        android:id="@+id/iv_game_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:round_corner_radius="8dp"
        app:round_type="round"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="10sp"
        android:textColor="@color/color_FFFFFF"
        android:ellipsize="end"
        android:id="@+id/tv_game_name"
        android:paddingLeft="6dp"
        android:paddingTop="2dp"
        android:paddingRight="6dp"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:singleLine="true"
        android:layout_marginStart="12dp"
        android:paddingHorizontal="6dp"
        android:paddingVertical="2dp"
        app:layout_constraintStart_toEndOf="@+id/iv_game_icon"
        app:layout_constraintTop_toTopOf="@+id/iv_game_icon"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@+id/tv_game_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:maxLines="1"
        android:singleLine="true"
        android:alpha="0.5"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_game_icon"
        app:layout_constraintStart_toEndOf="@+id/iv_game_icon"/>
    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
        android:id="@+id/iv_room_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="@+id/iv_game_icon"
        app:layout_constraintTop_toBottomOf="@+id/iv_game_icon"
        app:round_corner_radius="8dp"
        app:round_type="round"/>
    <Space
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iv_room_icon"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="13sp"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:gravity="start"
        android:id="@+id/tv_room_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="1"
        android:singleLine="true"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@+id/iv_room_icon"
        app:layout_constraintTop_toTopOf="@+id/iv_room_icon"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_country_icon"
        android:layout_width="20dp"
        android:layout_height="13dp"
        android:layout_marginTop="8dp"
        android:scaleType="fitXY"
        android:adjustViewBounds="true"
        app:layout_constraintStart_toStartOf="@+id/tv_room_name"
        app:layout_constraintTop_toBottomOf="@+id/tv_room_name"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_room_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_room_icon"
        app:layout_constraintStart_toStartOf="@+id/iv_country_icon">
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_1"
            android:layout_width="20dp"
            android:layout_height="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:round_border_color="@color/color_b2ffffff"
            app:round_border_width="1dp"
            app:round_type="circle"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_2"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_1"
            app:layout_constraintStart_toStartOf="@+id/iv_avatar_1"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_1"
            app:round_border_color="@color/color_b2ffffff"
            app:round_border_width="1dp"
            app:round_type="circle"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_3"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_2"
            app:layout_constraintStart_toStartOf="@+id/iv_avatar_2"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_2"
            app:round_border_color="@color/color_b2ffffff"
            app:round_border_width="1dp"
            app:round_type="circle"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_4"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_3"
            app:layout_constraintStart_toStartOf="@+id/iv_avatar_3"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_3"
            app:round_border_color="@color/color_b2ffffff"
            app:round_border_width="1dp"
            app:round_type="circle"/>
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_avatar_5"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_avatar_4"
            app:layout_constraintStart_toStartOf="@+id/iv_avatar_4"
            app:layout_constraintTop_toTopOf="@+id/iv_avatar_4"
            app:round_border_color="@color/color_b2ffffff"
            app:round_border_width="1dp"
            app:round_type="circle"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_live"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="2dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_room_hot_value"
        app:layout_constraintEnd_toStartOf="@+id/tv_room_online_count"
        app:layout_constraintTop_toTopOf="@+id/tv_room_hot_value"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_room_online_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_marginStart="2dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_room_hot_value"
        app:layout_constraintEnd_toStartOf="@+id/tv_room_hot_value"
        app:layout_constraintTop_toTopOf="@+id/tv_room_hot_value"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_room_hot_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="3dp"
        android:drawableStart="@mipmap/discover_room_hot_label_ic"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_room_icon"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
