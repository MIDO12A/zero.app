<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/music_panel_bg"
    android:paddingLeft="14dp"
    android:paddingTop="22dp"
    android:paddingRight="14dp"
    android:paddingBottom="24dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="14dp">
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="#ffffff"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tv_music_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/room_music_title_tips"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.yuehai.p١١٣ui.widget.widget.CustomSeekBar
        android:id="@+id/seekbar_music"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:progress="0"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        app:isSeekable="false"
        app:layout_constraintBottom_toBottomOf="@+id/tv_current_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_music_name"
        app:layout_constraintTop_toTopOf="@+id/tv_current_time"
        app:progressbarColor="@color/color_FFD98B2B"
        app:thumbDrawable="@mipmap/music_dian_ic"
        app:thumbHeight="12dp"
        app:thumbWidth="12dp"
        app:trackColor="@color/color_33FFFFFF"
        app:trackHeight="6dp"
        app:trackRadius="20dp"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="12sp"
        android:textColor="@color/color_FFFFFF"
        android:id="@+id/tv_current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:text="00:00"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_music_name"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="12sp"
        android:textColor="@color/color_FFFFFF"
        android:id="@+id/tv_total_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        app:layout_constraintBottom_toBottomOf="@+id/tv_current_time"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_current_time"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_operate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_current_time">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btn_mode"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/music_list_loop_ic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@drawable/music_play_bg"
            android:paddingLeft="12dp"
            android:paddingTop="4dp"
            android:paddingRight="12dp"
            android:paddingBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btn_prev"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/music_previous_ic"
                android:layout_marginEnd="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/btn_play"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btn_play"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@mipmap/music_play_ic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/btn_next"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@mipmap/music_next_ic"
                android:layout_marginStart="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/btn_play"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btn_music_list"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/music_list_ic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/color_80ffffff"
        android:id="@+id/tv_music"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/music_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_operate"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/color_80ffffff"
        android:id="@+id/tv_music_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        app:layout_constraintBottom_toBottomOf="@+id/tv_music"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_music"/>
    <com.yuehai.p١١٣ui.widget.widget.CustomSeekBar
        android:id="@+id/seekbar_music_volume"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:progress="0"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        app:isSeekable="true"
        app:layout_constraintBottom_toBottomOf="@+id/tv_music"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_music"
        app:progressbarColor="@color/color_FFD98B2B"
        app:thumbDrawable="@mipmap/music_dian_ic"
        app:thumbHeight="12dp"
        app:thumbWidth="12dp"
        app:trackColor="@color/color_33FFFFFF"
        app:trackHeight="6dp"
        app:trackRadius="20dp"/>
    <TextView
        android:textSize="11sp"
        android:textColor="@color/color_80ffffff"
        android:id="@+id/tv_voice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/music_voice_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_music"/>
    <com.yuehai.p١١٣ui.widget.widget.CustomSeekBar
        android:id="@+id/seekbar_voice_volume"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:progress="50"
        android:layout_marginStart="44dp"
        android:layout_marginEnd="44dp"
        app:isSeekable="true"
        app:layout_constraintBottom_toBottomOf="@+id/tv_voice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_voice"
        app:maxValue="100"
        app:progressbarColor="@color/color_FFD98B2B"
        app:thumbDrawable="@mipmap/music_dian_ic"
        app:thumbHeight="12dp"
        app:thumbWidth="12dp"
        app:trackColor="@color/color_33FFFFFF"
        app:trackHeight="6dp"
        app:trackRadius="20dp"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="11sp"
        android:textColor="@color/color_80ffffff"
        android:id="@+id/tv_voice_volume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        app:layout_constraintBottom_toBottomOf="@+id/tv_voice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_voice"/>
</androidx.constraintlayout.widget.ConstraintLayout>
