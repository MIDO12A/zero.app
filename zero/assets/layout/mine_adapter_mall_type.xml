<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="85dp">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_type_select"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@mipmap/mine_mall_type_item_bg"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_type_bg"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@mipmap/mine_mall_type_head_wear_pre_ic"
        app:layout_constraintBottom_toTopOf="@+id/tv_type_name"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <com.yuehai.p١١٣ui.widget.text.MarqueeTextView
        android:textSize="14sp"
        android:textColor="@color/color_80FAE9B5"
        android:id="@+id/tv_type_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
