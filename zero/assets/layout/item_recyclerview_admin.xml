<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_15"
    android:layout_marginStart="@dimen/dp_5"
    android:layout_marginEnd="@dimen/dp_5">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idItemBottom"
        android:paddingTop="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/idUserAvtar"
            android:layout_width="@dimen/dp_50"
            android:layout_height="@dimen/dp_50"
            android:layout_marginStart="@dimen/dp_5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/id_online_middle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/dp_5"
            app:layout_constraintStart_toEndOf="@+id/idUserAvtar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.7">
            <ImageView
                android:id="@+id/idCountryFlag"
                android:visibility="gone"
                android:layout_width="@dimen/dp_21"
                android:layout_height="@dimen/dp_19"
                android:layout_marginStart="@dimen/dp_5"
                android:layout_marginEnd="@dimen/dp_70"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/color_333333"
                android:id="@+id/idNickName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="abcdefghijklmnopq"
                android:alpha="0.9"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintStart_toEndOf="@+id/idCountryFlag"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/idSex"
                android:layout_width="@dimen/dp_17"
                android:layout_height="@dimen/dp_17"
                android:layout_marginTop="@dimen/dp_2"
                android:src="@mipmap/ic_sex_girl"
                android:layout_marginStart="@dimen/dp_5"
                android:layout_marginEnd="@dimen/dp_70"
                app:layout_constraintStart_toEndOf="@+id/idNickName"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/idIDicon"
                android:visibility="gone"
                android:layout_width="@dimen/dp_25"
                android:layout_height="@dimen/dp_25"
                android:src="@mipmap/id"
                android:layout_marginStart="@dimen/dp_5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/idNickName"/>
            <TextView
                android:textSize="@dimen/sp_15"
                android:id="@+id/idIDValue"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_25"
                android:layout_marginTop="@dimen/dp_3"
                android:text="ID 123456789"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintStart_toEndOf="@+id/idIDicon"
                app:layout_constraintTop_toBottomOf="@+id/idNickName"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:textColor="@color/color_9BA1B6"
            android:id="@+id/idCancel"
            android:background="@drawable/shape_edittext_a"
            android:paddingTop="@dimen/dp_5"
            android:paddingBottom="@dimen/dp_5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Cancle"
            android:paddingStart="@dimen/dp_8"
            android:paddingEnd="@dimen/dp_8"
            android:layout_marginEnd="@dimen/dp_5"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.15"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
