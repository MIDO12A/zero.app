<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/audio_content_ll"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/audio_play_iv"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/chat_audio_play_btn_ic"
            android:layout_marginEnd="8dp"/>
        <ImageView
            android:background="@drawable/chat_voice_sound_waves"
            android:layout_width="0dp"
            android:layout_height="21dp"
            android:scaleType="center"
            android:layout_weight="1"/>
        <TextView
            android:textSize="14.5sp"
            android:textColor="#000000"
            android:layout_gravity="center_vertical"
            android:id="@+id/audio_time_tv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"/>
    </LinearLayout>
    <com.tencent.qcloud.tuikit.timcommon.minimalistui.widget.message.TimeInLineTextLayout
        android:layout_gravity="end"
        android:id="@+id/time_in_line_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
