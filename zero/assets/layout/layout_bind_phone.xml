<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/layout_bind_phone_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idPartTitle"
        android:background="@drawable/shape_white_juxing1"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_39"
        android:layout_marginTop="@dimen/dp_35"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/idBack"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:src="@mipmap/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="@dimen/sp_19"
            android:textColor="@color/black"
            android:id="@+id/idTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/phoneBind"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/dp_50"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idPartTitle">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingStart="15dp"
                android:paddingEnd="15dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:background="@drawable/shape_edittext_a"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="25dp"
                        android:paddingStart="15dp"
                        android:paddingEnd="5dp">
                        <LinearLayout
                            android:id="@+id/ll_area"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent">
                            <TextView
                                android:textSize="15sp"
                                android:textColor="#ff343434"
                                android:layout_gravity="center_vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+"/>
                            <TextView
                                android:textSize="14sp"
                                android:textColor="#ff16151a"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_area"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"/>
                            <ImageView
                                android:layout_gravity="center_vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@mipmap/ic_jiantou"
                                android:layout_marginStart="5dp"/>
                        </LinearLayout>
                        <com.yoopo.voiroo.other.SureClearEditText
                            android:textSize="14dp"
                            android:textColor="@color/black"
                            android:textColorHint="#9ba1b6"
                            android:gravity="start|center_vertical"
                            android:id="@+id/et_mobile"
                            android:background="@null"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="@string/edit_hint"
                            android:maxLength="11"
                            android:inputType="number"
                            android:paddingStart="10dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="25dp">
                        <com.yoopo.voiroo.other.SureClearEditText
                            android:textSize="14dp"
                            android:textColor="@color/color_333333"
                            android:textColorHint="#9ba1b6"
                            android:gravity="start|center_vertical"
                            android:id="@+id/et_code"
                            android:background="@drawable/shape_edittext_a"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:hint="@string/phone_send_to"
                            android:maxLength="11"
                            android:layout_weight="1"
                            android:inputType="number"/>
                        <TextView
                            android:textSize="@dimen/sp_12"
                            android:textColor="@color/color_894916"
                            android:gravity="center"
                            android:layout_gravity="end|center_vertical"
                            android:id="@+id/tv_get_code"
                            android:background="@drawable/shapea"
                            android:layout_width="140dp"
                            android:layout_height="match_parent"
                            android:text="@string/get_verification_code"
                            android:includeFontPadding="false"
                            android:layout_marginStart="@dimen/dp_5"/>
                    </LinearLayout>
                    <com.yoopo.voiroo.other.SureClearEditText
                        android:textSize="14dp"
                        android:textColor="@color/color_333333"
                        android:textColorHint="#9ba1b6"
                        android:id="@+id/et_pwd"
                        android:background="@drawable/shape_edittext_a"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="25dp"
                        android:hint="@string/enter_password_01"
                        android:inputType="textPassword"
                        android:paddingStart="15dp"/>
                </LinearLayout>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/sp_15"
                android:textColor="@color/color_844B2E"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/id_bind"
                android:background="@drawable/shapea"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="35dp"
                android:text="@string/sure"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"/>
        </LinearLayout>
    </RelativeLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
