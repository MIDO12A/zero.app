<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_gift"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="15dp"
        android:src="@mipmap/room_gift_ic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_chat"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/room_chat_ic"
        android:layout_marginStart="14dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_emoj"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/room_emoj_ic"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
        app:layout_constraintStart_toEndOf="@+id/iv_chat"
        app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_mic_state"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/room_micphone_ic"
        android:layout_marginStart="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
        app:layout_constraintStart_toEndOf="@+id/iv_emoj"
        app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_function"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/room_function_ic"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="14dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_msg"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/room_msg_ic"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
        app:layout_constraintEnd_toStartOf="@+id/iv_function"
        app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="12sp"
        android:textColor="@color/color_FFFFFF"
        android:gravity="center"
        android:id="@+id/tv_msg_count"
        android:background="@drawable/shape_red_point_bg"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:layout_marginStart="18dp"
        android:paddingHorizontal="4dp"
        app:layout_constraintHeight_min="10dp"
        app:layout_constraintStart_toStartOf="@+id/iv_msg"
        app:layout_constraintTop_toTopOf="@+id/iv_msg"
        app:layout_constraintWidth_min="17dp"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_music"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/room_set_music_ic"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_gift"
        app:layout_constraintEnd_toStartOf="@+id/iv_msg"
        app:layout_constraintTop_toTopOf="@+id/iv_gift"/>
</androidx.constraintlayout.widget.ConstraintLayout>
