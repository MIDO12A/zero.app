<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/idRootView"
    android:background="@color/color_16151A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.youth.banner.Banner
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.widget.StatusBarHeightImageView
            android:id="@+id/status_bar_height"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/status_bar_height">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_back"
                android:background="@mipmap/ic_back_white"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:rotation="@integer/locale_mirror_flip"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_more_operation"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@mipmap/mine_user_info_more_ic"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinator"
        android:background="@color/transparent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="88dp"
        app:layout_constraintTop_toTopOf="parent">
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:background="@color/transparent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_scrollFlags="snap|enterAlways">
            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_scrollFlags="exitUntilCollapsed|scroll">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_collapseMode="pin">
                    <com.tencent.qgame.animplayer.AnimView
                        android:id="@+id/iv_vip_level_bg"
                        android:layout_width="match_parent"
                        android:layout_height="236dp"
                        android:scaleType="centerCrop"
                        android:elevation="1dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:orientation="vertical"
                        android:id="@+id/ll_info"
                        android:background="@drawable/mine_user_bg_shape_12"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="37dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <View
                            android:id="@+id/view_space"
                            android:layout_width="match_parent"
                            android:layout_height="70dp"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="12sp"
                            android:textColor="@color/color_80ffffff"
                            android:id="@+id/tv_signature"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:drawablePadding="12dp"
                            android:drawableStart="@mipmap/mine_user_sign_ic"
                            android:layout_marginHorizontal="16dp"/>
                        <com.yuehai.p١١٣ui.widget.widget.RankLevelView
                            android:id="@+id/level_view"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="16dp"
                            android:layout_marginTop="12dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginHorizontal="16dp"/>
                        <com.yuehai.p١١٣ui.widget.widget.medal.UserMedalView
                            android:id="@+id/user_medal_view"
                            android:paddingTop="7dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="16dp"
                            android:layout_marginRight="16dp"
                            android:layout_marginHorizontal="16dp"/>
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp">
                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:orientation="horizontal"
                                android:background="@drawable/mine_user_info_shape_2_bg"
                                android:layout_width="match_parent"
                                android:layout_height="68dp"
                                android:layout_marginLeft="16dp"
                                android:layout_marginTop="20dp"
                                android:layout_marginRight="16dp"
                                android:weightSum="3"
                                android:layout_marginHorizontal="16dp"
                                app:layout_constraintTop_toTopOf="parent">
                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:id="@+id/ll_follow"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1"
                                    android:foregroundGravity="center">
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/color_FFFFFF"
                                        android:id="@+id/tv_follow_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:textSize="11sp"
                                        android:textColor="@color/color_9BA1B6"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/mine_following"/>
                                </androidx.appcompat.widget.LinearLayoutCompat>
                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:id="@+id/ll_fan"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1">
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/color_FFFFFF"
                                        android:id="@+id/tv_fan_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:textSize="11sp"
                                        android:textColor="@color/color_9BA1B6"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/mine_fan"/>
                                </androidx.appcompat.widget.LinearLayoutCompat>
                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:id="@+id/ll_visitor"
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="1">
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/color_FFFFFF"
                                        android:id="@+id/tv_visitor_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"/>
                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:textSize="11sp"
                                        android:textColor="@color/color_9BA1B6"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="4dp"
                                        android:text="@string/mine_visitors"/>
                                </androidx.appcompat.widget.LinearLayoutCompat>
                            </androidx.appcompat.widget.LinearLayoutCompat>
                        </androidx.constraintlayout.widget.ConstraintLayout>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclervie_tab"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:layout_marginTop="20dp"
                            android:layout_marginRight="8dp"
                            android:layout_marginHorizontal="8dp"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                    <com.yuehai.p١١٣ui.widget.widget.UserAvatarView
                        android:id="@+id/ll_avatar"
                        android:layout_width="116dp"
                        android:layout_height="116dp"
                        android:layout_marginTop="7dp"
                        android:layout_marginStart="16dp"
                        android:elevation="2dp"
                        app:avatarHeight="116dp"
                        app:avatarMargin="16dp"
                        app:avatarWidth="116dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_user_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        app:layout_constraintBottom_toBottomOf="@+id/ll_avatar"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/ll_avatar"
                        app:layout_constraintTop_toTopOf="@+id/ll_avatar">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_FFFFFF"
                            android:ellipsize="end"
                            android:id="@+id/tv_nick_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxLines="1"
                            android:maxEms="18"
                            app:layout_constrainedWidth="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintWidth_max="180dp"/>
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_sex"
                            android:layout_width="18dp"
                            android:layout_height="16dp"
                            android:src="@mipmap/sex_male_ic"
                            android:layout_marginStart="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/tv_nick_name"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_country"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@mipmap/sex_male_ic"
                            android:layout_marginStart="8dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/iv_sex"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                    <com.yuehai.p١١٣ui.widget.widget.UserIdView
                        android:id="@+id/user_id_view"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:layout_marginStart="16dp"
                        app:layout_constraintStart_toEndOf="@+id/ll_avatar"
                        app:layout_constraintTop_toBottomOf="@+id/cl_user_info"/>
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/ll_live"
                        android:background="@drawable/mine_live_shape"
                        android:paddingLeft="9dp"
                        android:paddingRight="9dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="71dp"
                        android:layout_marginStart="30dp"
                        android:layout_marginEnd="16dp"
                        android:paddingHorizontal="9dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <androidx.appcompat.widget.AppCompatImageView
                            android:layout_width="wrap_content"
                            android:layout_height="22dp"
                            android:src="@mipmap/mine_live_label"/>
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textSize="10sp"
                            android:textColor="@color/color_FFFFFF"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/mine_info_live"
                            android:layout_marginStart="3dp"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </androidx.constraintlayout.widget.ConstraintLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerview_tab"
                    android:paddingTop="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </com.google.android.material.appbar.CollapsingToolbarLayout>
        </com.google.android.material.appbar.AppBarLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_gravity="fill_vertical"
            android:id="@+id/recyclerview_wall"
            android:background="@color/color_16151A"
            android:paddingLeft="16dp"
            android:paddingTop="16dp"
            android:paddingRight="16dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/idPartBottom"
        android:background="@color/color_16151A"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/idFollow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivFollowIcon"
                android:tag="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@mipmap/mine_follow_nor_ic"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textColor="@color/color_FAE9B5"
                android:id="@+id/idTvFollowStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Follow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivFollowIcon"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_chat"
            android:background="@drawable/mine_user_info_chat_bg"
            android:paddingLeft="36dp"
            android:paddingRight="36dp"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginEnd="16dp"
            android:paddingHorizontal="36dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/idPartGift"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivChatIcon"
                android:layout_width="19dp"
                android:layout_height="17dp"
                android:src="@mipmap/mine_chat_ic"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/color_FFFAE9B5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Chat"
                android:layout_marginStart="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@+id/ivChatIcon"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/idPartGift"
            android:background="@drawable/shape_gift_bg"
            android:paddingTop="@dimen/dp_10"
            android:paddingBottom="@dimen/dp_10"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/dp_20"
            android:paddingEnd="@dimen/dp_20"
            android:layout_marginEnd="@dimen/dp_20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivGiftIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@mipmap/ic_gift_2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="@dimen/sp_17"
                android:textColor="@color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gift"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintStart_toEndOf="@+id/ivGiftIcon"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
