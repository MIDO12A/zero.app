<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.56"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_game_teaming"
        android:background="@mipmap/discover_game_teaming_ic"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="18dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/guideline"
        app:layout_constraintHeight_min="210dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="18dp"
        app:layout_constraintBottom_toBottomOf="@+id/iv_game_teaming"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/iv_game_teaming"
        app:layout_constraintTop_toTopOf="@+id/iv_game_teaming"
        app:layout_constraintWidth_percent="0.34">
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@mipmap/home_rank_bg"
            android:scaleType="fitXY"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_wealth"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:layout_marginBottom="3dp"
            android:src="@mipmap/home_wealth_ic"
            android:scaleType="fitXY"
            android:rotationY="@integer/locale_mirror_flip"
            android:layout_marginHorizontal="6dp"
            app:layout_constraintBottom_toTopOf="@+id/iv_charm"
            app:layout_constraintDimensionRatio="109:47"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_wealth_avatar"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_marginTop="7dp"
            android:layout_marginEnd="19dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guideline_70"
            app:layout_constraintTop_toTopOf="@+id/iv_wealth"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_charm"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:layout_marginBottom="3dp"
            android:src="@mipmap/home_charm_ic"
            android:scaleType="fitXY"
            android:rotationY="@integer/locale_mirror_flip"
            android:layout_marginHorizontal="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/iv_room"
            app:layout_constraintDimensionRatio="109:47"
            app:layout_constraintStart_toStartOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_charm_avatar"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_marginTop="7dp"
            android:layout_marginEnd="19dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guideline_70"
            app:layout_constraintTop_toTopOf="@+id/iv_charm"/>
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guideline_70"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintGuide_percent="0.63"
            app:layout_constraintStart_toStartOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_room"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:layout_marginBottom="7dp"
            android:src="@mipmap/home_room_ic"
            android:scaleType="fitXY"
            android:rotationY="@integer/locale_mirror_flip"
            android:layout_marginHorizontal="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="109:47"
            app:layout_constraintStart_toStartOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_room_avatar"
            android:layout_width="29dp"
            android:layout_height="29dp"
            android:layout_marginTop="7dp"
            android:layout_marginEnd="19dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guideline_70"
            app:layout_constraintTop_toTopOf="@+id/iv_room"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <HorizontalScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fillViewport="true"
        android:layout_marginStart="21dp"
        app:layout_constraintTop_toBottomOf="@+id/iv_game_teaming">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="62dp">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/idEnjoyMusic"
                android:layout_width="135dp"
                android:layout_height="match_parent"
                android:src="@mipmap/discover_music_ic"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/idChattingFriend"
                android:layout_width="135dp"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_chatting_friend"
                android:layout_marginStart="6dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/idSocialSharing"
                android:layout_width="135dp"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_social_sharing"
                android:layout_marginStart="6dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_hobby"
                android:layout_width="135dp"
                android:layout_height="match_parent"
                android:src="@mipmap/discover_header_item_hobby_ic"
                android:layout_marginStart="6dp"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_party"
                android:layout_width="135dp"
                android:layout_height="match_parent"
                android:src="@mipmap/discover_header_item_party_ic"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="16dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </HorizontalScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
