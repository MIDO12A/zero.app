<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/shape_white_juxing"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/sp_18"
        android:gravity="center"
        android:id="@+id/idSeatActionTakeMic"
        android:paddingTop="@dimen/dp_10"
        android:paddingBottom="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:text="@string/SeatActionTakeMic"/>
    <View
        android:id="@+id/idDriver1"
        android:background="@color/color_9BA1B6"
        android:layout_width="match_parent"
        android:layout_height="0.6dp"
        android:layout_marginTop="@dimen/dp_10"
        android:alpha="0.2"/>
    <TextView
        android:textSize="@dimen/sp_18"
        android:gravity="center"
        android:id="@+id/idSeatActionInviteSeat"
        android:paddingTop="@dimen/dp_10"
        android:paddingBottom="@dimen/dp_10"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:text="@string/SeatActionInvitemic"/>
    <View
        android:id="@+id/idDriver2"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/dp_10"
        android:alpha="0.1"/>
    <TextView
        android:textSize="@dimen/sp_18"
        android:gravity="center"
        android:id="@+id/idSeatActionLockSeat"
        android:paddingTop="@dimen/dp_10"
        android:paddingBottom="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:text="@string/SeatActionLockSeat"/>
    <View
        android:id="@+id/idDriver3"
        android:background="@color/color_9BA1B6"
        android:layout_width="match_parent"
        android:layout_height="0.6dp"
        android:layout_marginTop="@dimen/dp_10"
        android:alpha="0.2"/>
    <TextView
        android:textSize="@dimen/sp_18"
        android:gravity="center"
        android:id="@+id/idSeatActionMicStatus"
        android:paddingTop="@dimen/dp_10"
        android:paddingBottom="@dimen/dp_10"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:text="@string/idSeatActionLockMic"/>
    <View
        android:id="@+id/idDriver4"
        android:background="@color/color_9BA1B6"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="@dimen/dp_15"
        android:alpha="0.05"/>
    <TextView
        android:textSize="@dimen/sp_18"
        android:gravity="center"
        android:id="@+id/idSeatActionCancel"
        android:paddingTop="@dimen/dp_10"
        android:paddingBottom="@dimen/dp_20"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:text="@string/cancel"/>
</LinearLayout>
