<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_agency"
        android:background="@mipmap/union_agency_item_bg"
        android:paddingLeft="13dp"
        android:paddingTop="16dp"
        android:paddingRight="13dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginRight="16dp"
        android:layout_marginHorizontal="16dp"
        android:paddingHorizontal="13dp"
        android:paddingVertical="16dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/tv_time_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_next_1"
            android:visibility="gone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/common_next_3_ic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rule_1"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/union_sub_help_ic"
            android:paddingHorizontal="4dp"
            app:layout_constraintEnd_toStartOf="@+id/iv_next_1"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_diamond_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/common_diamond_ic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_1"
            app:layout_constraintWidth_percent="0.5"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_rate_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/union_rate_1_ic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_1"
            app:layout_constraintWidth_percent="0.5"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:id="@+id/tv_income_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="@string/union_diamond_income"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_diamond_1"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="@string/union_diamond_rate"
            app:layout_constraintStart_toStartOf="@+id/tv_rate_1"
            app:layout_constraintTop_toBottomOf="@+id/tv_diamond_1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_individual"
        android:background="@mipmap/union_agency_item_bg"
        android:paddingLeft="13dp"
        android:paddingTop="16dp"
        android:paddingRight="13dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="16dp"
        android:layout_marginHorizontal="16dp"
        android:paddingHorizontal="13dp"
        android:paddingVertical="16dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/tv_time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_next_2"
            android:visibility="gone"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/common_next_3_ic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rule_2"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/union_sub_help_ic"
            android:paddingHorizontal="4dp"
            app:layout_constraintEnd_toStartOf="@+id/iv_next_2"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_diamond_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/common_diamond_ic"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_2"
            app:layout_constraintWidth_percent="0.5"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_rate_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="13dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/union_member_count_2_ic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_2"
            app:layout_constraintWidth_percent="0.5"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="@string/union_diamond_income"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_diamond_2"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:text="@string/union_account_host"
            app:layout_constraintStart_toStartOf="@+id/tv_rate_2"
            app:layout_constraintTop_toBottomOf="@+id/tv_diamond_2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:background="@color/color_FF282828"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:paddingVertical="14dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_979797"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_tab_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/union_nickname_title"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_979797"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_tab_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/union_receive_gift_title"
            android:layout_weight="1"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_979797"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/tv_tab_title_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/union_active_day_title"
            android:layout_weight="1"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.appcompat.widget.LinearLayoutCompat>
