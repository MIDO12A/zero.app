<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_month_1"
        android:background="@mipmap/union_agency_item_bg"
        android:paddingLeft="13dp"
        android:paddingTop="16dp"
        android:paddingRight="13dp"
        android:paddingBottom="19dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="13dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_time_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_next_1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/common_next_3_ic"
            android:rotationY="@integer/locale_mirror_flip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_diamond_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/common_diamond_ic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_income_1"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_1"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:id="@+id/tv_income_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/union_diamond_income"
            app:layout_constraintBottom_toBottomOf="@+id/tv_diamond_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_diamond_1"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_month_2"
        android:background="@mipmap/union_agency_item_bg"
        android:paddingLeft="13dp"
        android:paddingTop="16dp"
        android:paddingRight="13dp"
        android:paddingBottom="19dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:paddingHorizontal="13dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_next_2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/common_next_3_ic"
            android:rotationY="@integer/locale_mirror_flip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_diamond_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/common_diamond_ic"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_income_2"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_2"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:id="@+id/tv_income_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/union_diamond_income"
            app:layout_constraintBottom_toBottomOf="@+id/tv_diamond_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_diamond_2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
