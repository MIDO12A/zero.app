<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/idRootView"
    android:tag="layout/layout_register_byphone_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:background="@mipmap/bg_login"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:paddingTop="@dimen/dp_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/close"
                android:background="@mipmap/ic_back"
                android:layout_width="@dimen/dp_50"
                android:layout_height="@dimen/dp_50"
                android:layout_marginTop="@dimen/dp_20"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingStart="15dp"
                android:paddingEnd="15dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#ff333333"
                            android:id="@+id/tv_title"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/dp_100"
                            android:layout_marginTop="@dimen/sp_15"
                            android:text="@string/welcome_register"
                            android:drawablePadding="5dp"/>
                        <ImageView
                            android:layout_gravity="end"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dp_100"
                            android:src="@mipmap/bg_login_b"
                            android:layout_marginEnd="@dimen/dp_5"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:background="@drawable/shape_edittext_a"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="25dp"
                        android:paddingStart="15dp"
                        android:paddingEnd="5dp">
                        <LinearLayout
                            android:id="@+id/ll_area"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent">
                            <TextView
                                android:textSize="15sp"
                                android:textColor="#ff343434"
                                android:layout_gravity="center_vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+"/>
                            <TextView
                                android:textSize="14sp"
                                android:textColor="#ff16151a"
                                android:layout_gravity="center_vertical"
                                android:id="@+id/tv_area"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1"/>
                            <ImageView
                                android:layout_gravity="center_vertical"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@mipmap/ic_jiantou"
                                android:layout_marginStart="5dp"/>
                        </LinearLayout>
                        <EditText
                            android:textSize="14dp"
                            android:textColor="@color/black"
                            android:textColorHint="#9ba1b6"
                            android:gravity="start|center_vertical"
                            android:id="@+id/et_mobile"
                            android:background="@null"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="@string/edit_hint"
                            android:maxLength="13"
                            android:inputType="number"
                            android:paddingStart="10dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="15dp">
                        <EditText
                            android:textSize="14dp"
                            android:textColor="@color/color_333333"
                            android:textColorHint="#9ba1b6"
                            android:gravity="start|center_vertical"
                            android:id="@+id/et_code"
                            android:background="@drawable/shape_edittext_a"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="@string/input_verify_code"
                            android:maxLength="6"
                            android:layout_weight="1"
                            android:inputType="number"
                            android:paddingStart="15dp"/>
                        <TextView
                            android:textSize="@dimen/sp_12"
                            android:textColor="@color/color_894916"
                            android:gravity="center"
                            android:layout_gravity="end|center_vertical"
                            android:id="@+id/tv_get_code"
                            android:background="@drawable/shapea"
                            android:layout_width="140dp"
                            android:layout_height="match_parent"
                            android:text="@string/get_verification_code"
                            android:includeFontPadding="false"
                            android:layout_marginStart="@dimen/dp_5"/>
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/et_password"
                        android:background="@drawable/shape_edittext_a"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp">
                        <EditText
                            android:textSize="@dimen/sp_14"
                            android:textColor="@color/black"
                            android:textColorHint="@color/color_9BA1B6"
                            android:id="@+id/et_pwd"
                            android:background="@android:color/transparent"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:hint="@string/hint_input_password"
                            android:maxLength="8"
                            android:layout_weight="1"
                            android:inputType="textPassword"
                            android:imeOptions="actionDone"
                            android:paddingStart="@dimen/dp_15"/>
                        <ImageView
                            android:id="@+id/iv_password_eye"
                            android:layout_width="20dp"
                            android:layout_height="25dp"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="10dp"
                            android:src="@mipmap/ic_password_invisiable"/>
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
            <TextView
                android:textSize="@dimen/sp_17"
                android:textColor="@android:color/darker_gray"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:id="@+id/id_sure"
                android:background="@drawable/shapec"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="23dp"
                android:text="@string/sure"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"/>
        </LinearLayout>
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>
