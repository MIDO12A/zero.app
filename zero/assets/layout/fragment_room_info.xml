<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.yuehai.p١١٣ui.widget.widget.StatusBarHeightImageView
        android:id="@+id/status_bar_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_room_info"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingVertical="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/status_bar_height"
        app:layout_constraintWidth_percent="0.7">
        <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
            android:id="@+id/iv_room_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:round_corner_radius="8dp"
            app:round_type="round"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="13sp"
            android:textColor="@color/color_FFFFFF"
            android:ellipsize="end"
            android:id="@+id/tv_room_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="1"
            android:layout_marginStart="5dp"
            app:layout_constraintStart_toEndOf="@+id/iv_room_avatar"
            app:layout_constraintTop_toTopOf="@+id/iv_room_avatar"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="10sp"
            android:textColor="@color/color_b2ffffff"
            android:id="@+id/tv_room_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/iv_room_avatar"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@+id/tv_room_name"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_room_lock"
            android:visibility="gone"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@mipmap/room_lock_state_ic"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_room_hot_value"
            app:layout_constraintStart_toEndOf="@+id/tv_room_id"
            app:layout_constraintTop_toTopOf="@+id/tv_room_hot_value"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="10sp"
            android:textColor="@color/color_b2ffffff"
            android:id="@+id/tv_room_hot_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="2dp"
            android:drawableStart="@mipmap/room_hot_logo_ic"
            android:layout_marginStart="2dp"
            app:layout_constraintBottom_toBottomOf="@+id/iv_room_avatar"
            app:layout_constraintStart_toEndOf="@+id/iv_room_lock"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/iv_room_avatar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_room_hot_value">
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="10sp"
                android:textColor="@color/color_FFFFFF"
                android:ellipsize="end"
                android:id="@+id/tv_room_type"
                android:background="@drawable/room_header_type_bg_1"
                android:paddingLeft="4dp"
                android:paddingTop="1dp"
                android:paddingRight="4dp"
                android:paddingBottom="1dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_marginStart="2dp"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_game_them"
        android:background="@color/color_1AFFFFFF"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:paddingHorizontal="14dp"
        app:layout_constraintTop_toBottomOf="@+id/cl_room_info">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_game_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:scaleType="centerCrop"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:id="@+id/tv_game_type"
            android:paddingLeft="6dp"
            android:paddingTop="2dp"
            android:paddingRight="6dp"
            android:paddingBottom="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_game_icon"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.text.MarqueeTextView
            android:textColor="@color/color_80ffffff"
            android:ellipsize="end"
            android:gravity="start"
            android:id="@+id/tv_game_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cl_online_user"
            app:layout_constraintStart_toEndOf="@+id/tv_game_type"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_online_user"
            android:background="@mipmap/room_online_info_bg"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:paddingStart="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.yuehai.room.widget.OverlappingAvatarView
                android:id="@+id/flip_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/tv_online_num"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="11sp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_online_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableEnd="@mipmap/next_white_ic"
                android:layout_marginEnd="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_close"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@mipmap/room_exit_ic"
        android:layout_marginEnd="13dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
