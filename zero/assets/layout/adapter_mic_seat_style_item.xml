<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_pre_bg"
        android:layout_width="104dp"
        android:layout_height="160dp"
        android:layout_marginBottom="6dp"
        android:src="@mipmap/room_bg_seat_pre"
        app:layout_constraintBottom_toTopOf="@+id/tv_mic_num"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
        android:id="@+id/iv_img"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:src="@mipmap/room_bg_vip_seat_10"
        android:scaleType="fitXY"
        app:layout_constraintBottom_toBottomOf="@+id/iv_pre_bg"
        app:layout_constraintEnd_toEndOf="@+id/iv_pre_bg"
        app:layout_constraintStart_toStartOf="@+id/iv_pre_bg"
        app:layout_constraintTop_toTopOf="@+id/iv_pre_bg"
        app:round_corner_radius="12dp"
        app:round_type="round"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="@color/color_FFFFFF"
        android:id="@+id/tv_mic_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/iv_pre_bg"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
