<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/tv_confirm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_head_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:src="@mipmap/room_create_room_bg"
                    android:scaleType="fitXY"
                    android:minHeight="172dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.yuehai.p١١٣ui.widget.widget.StatusBarHeightImageView
                    android:id="@+id/status_bar_height"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.yuehai.p١١٣ui.widget.widget.CommonTopBar
                    android:id="@+id/top_bar"
                    android:background="@color/transparent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/status_bar_height"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="24sp"
                    android:textColor="@color/color_16151A"
                    android:gravity="center_vertical"
                    android:id="@+id/tv_create_room_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/rom_create_title"
                    android:drawablePadding="4dp"
                    android:drawableStart="@mipmap/room_create_label_ic"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/top_bar"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.appcompat.widget.AppCompatImageView
                android:textColor="@color/color_1D1111"
                android:id="@+id/iv_avatar"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:src="@mipmap/common_camera_ic"
                android:scaleType="centerCrop"
                android:layout_marginStart="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cl_head_info"
                app:type="round"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_camera_logo"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:src="@mipmap/room_camera_logo_ic"
                app:layout_constraintBottom_toBottomOf="@+id/iv_camera"
                app:layout_constraintEnd_toEndOf="@+id/iv_camera"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="14sp"
                android:textColor="@color/color_16151A"
                android:id="@+id/tv_room_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/RoomName"
                android:layout_marginStart="16dp"
                app:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/iv_camera"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatEditText
                    android:textSize="13sp"
                    android:textColor="@color/color_16151A"
                    android:textColorHint="@color/color_9BA1B6"
                    android:id="@+id/et_room_name"
                    android:background="@drawable/room_create_introduce_bg"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginRight="16dp"
                    android:hint="@string/room_name_tips"
                    android:maxLength="20"
                    android:paddingStart="12dp"
                    android:paddingEnd="32dp"
                    android:layout_marginHorizontal="16dp"
                    android:paddingVertical="12dp"
                    app:layout_constraintHeight_min="49dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="12sp"
                    android:textColor="@color/color_9BA1B6"
                    android:id="@+id/tv_name_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/et_room_name"
                    app:layout_constraintEnd_toEndOf="@+id/et_room_name"
                    app:layout_constraintTop_toTopOf="@+id/et_room_name"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="14sp"
                android:textColor="@color/color_16151A"
                android:id="@+id/tv_topic_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/room_topic_name"
                android:layout_marginStart="16dp"
                app:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/et_room_name"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp">
                <androidx.appcompat.widget.AppCompatEditText
                    android:textSize="13sp"
                    android:textColor="@color/color_16151A"
                    android:textColorHint="@color/color_9BA1B6"
                    android:gravity="start|top"
                    android:id="@+id/et_topic_name"
                    android:background="@drawable/room_create_introduce_bg"
                    android:paddingLeft="12dp"
                    android:paddingTop="12dp"
                    android:paddingRight="12dp"
                    android:paddingBottom="32dp"
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginLeft="16dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginRight="16dp"
                    android:hint="@string/room_topic_hint"
                    android:maxLength="100"
                    android:layout_marginStart="16dp"
                    android:layout_marginHorizontal="16dp"
                    android:paddingHorizontal="12dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="12sp"
                    android:textColor="@color/color_9BA1B6"
                    android:id="@+id/tv_topic_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/et_topic_name"
                    app:layout_constraintEnd_toEndOf="@+id/et_topic_name"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="14sp"
                android:textColor="@color/color_16151A"
                android:id="@+id/tv_lock_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/room_lock_room_title"
                android:layout_marginStart="16dp"
                app:fontFamily="sans-serif-medium"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tv_topic_num"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_pwd"
                android:background="@drawable/room_create_introduce_bg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginRight="16dp"
                android:layout_marginHorizontal="16dp"
                app:layout_constraintHeight_min="50dp"
                app:layout_constraintTop_toBottomOf="@+id/tv_lock_name">
                <androidx.appcompat.widget.AppCompatEditText
                    android:enabled="false"
                    android:textSize="13sp"
                    android:textColor="@color/color_16151A"
                    android:textColorHint="@color/color_9BA1B6"
                    android:id="@+id/et_pwd"
                    android:background="@null"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/room_lock_room_hint"
                    android:maxLength="6"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:paddingEnd="32dp"
                    android:paddingVertical="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintHeight_min="49dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <CheckBox
                    android:id="@+id/cb_pwd"
                    android:background="@drawable/room_pwd_lock_bg"
                    android:layout_width="47dp"
                    android:layout_height="29dp"
                    android:button="@null"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="@color/color_FFFFFF"
        android:gravity="center"
        android:layout_gravity="bottom"
        android:id="@+id/tv_confirm"
        android:background="@drawable/btn_shape_cancel_12_bg"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="12dp"
        android:text="@string/mine_confirm"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintBottom_toTopOf="@+id/navigator_bottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <com.yuehai.p١١٣ui.widget.widget.NavigationBarSpacerView
        android:id="@+id/navigator_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
