<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/color_16151A"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_rank_top_bg"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:src="@mipmap/rank_wealth_header_bg"
        android:scaleType="fitXY"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_content"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:paddingStart="10dp"
        android:paddingEnd="5dp"
        android:paddingVertical="11dp"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_num_bg"
            android:layout_width="32dp"
            android:layout_height="38dp"
            android:src="@mipmap/rank_num_bg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="14sp"
            android:textColor="@color/color_FFFFFF"
            android:id="@+id/tv_num"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/iv_num_bg"
            app:layout_constraintEnd_toEndOf="@+id/iv_num_bg"
            app:layout_constraintStart_toStartOf="@+id/iv_num_bg"
            app:layout_constraintTop_toTopOf="@+id/iv_num_bg"/>
        <com.yuehai.p١١٣ui.widget.widget.UserVipAvatarView
            android:id="@+id/iv_avatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            app:avatarHeight="48dp"
            app:avatarMargin="12dp"
            app:avatarWidth="48dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_num_bg"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.widget.UserInfoView
            android:id="@+id/user_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@+id/iv_avatar"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.yuehai.p١١٣ui.widget.widget.UserIdView
            android:id="@+id/user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:layout_constraintStart_toStartOf="@+id/user_info"
            app:layout_constraintTop_toBottomOf="@+id/user_info"/>
        <com.yuehai.p١١٣ui.widget.widget.medal.UserLevelMedalView
            android:id="@+id/level_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/user_info"
            app:layout_constraintTop_toBottomOf="@+id/user_id"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textColor="@color/color_FAE9B5"
            android:id="@+id/tv_gold_increase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableStart="@mipmap/common_gold_ic_8"
            android:drawableEnd="@mipmap/rank_gold_increase_ic"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
