<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="start"
    android:orientation="vertical"
    android:id="@+id/forward_msg_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="locale">
    <TextView
        android:textSize="15.36sp"
        android:textColor="@color/black"
        android:ellipsize="end"
        android:gravity="start|center_vertical"
        android:id="@+id/msg_forward_title"
        android:layout_width="@dimen/forward_text_max_length"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/forward_text_max_length"
        android:maxLines="1"
        android:textDirection="locale"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="@dimen/forward_text_max_length"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <include
            android:id="@+id/first_line"
            layout="@layout/chat_forward_msg_content_line_layout"/>
        <include
            android:id="@+id/second_line"
            layout="@layout/chat_forward_msg_content_line_layout"/>
        <include
            android:id="@+id/third_line"
            layout="@layout/chat_forward_msg_content_line_layout"/>
    </LinearLayout>
    <View
        android:background="@drawable/chat_divide_line"
        android:layout_width="match_parent"
        android:layout_height="0.6dp"
        android:layout_marginTop="6dp"/>
    <TextView
        android:textSize="8.6sp"
        android:textColor="#888888"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/forward_chat_record"/>
</LinearLayout>
