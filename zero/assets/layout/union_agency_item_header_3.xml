<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_month_1"
        android:background="@mipmap/union_agency_item_bg"
        android:paddingLeft="13dp"
        android:paddingTop="16dp"
        android:paddingRight="13dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="13dp"
        android:paddingVertical="16dp">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_time_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_rate_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/union_rate_1_ic"
            android:layout_marginStart="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_rate_tip"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_1"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:id="@+id/tv_rate_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/union_diamond_rate_2"
            app:layout_constraintBottom_toBottomOf="@+id/tv_rate_1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_rate_1"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_next_1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/common_next_3_ic"
            android:rotationY="@integer/locale_mirror_flip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rule_1"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/union_sub_help_ic"
            android:paddingHorizontal="4dp"
            app:layout_constraintEnd_toStartOf="@+id/iv_next_1"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_month_2"
        android:background="@mipmap/union_agency_item_bg"
        android:paddingLeft="13dp"
        android:paddingTop="16dp"
        android:paddingRight="13dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingHorizontal="13dp"
        android:paddingVertical="16dp">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_next_2"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/common_next_3_ic"
            android:rotationY="@integer/locale_mirror_flip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_rule_2"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@mipmap/union_sub_help_ic"
            android:paddingHorizontal="4dp"
            app:layout_constraintEnd_toStartOf="@+id/iv_next_2"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_time_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/color_FFFFF5AD"
            android:id="@+id/tv_rate_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:drawablePadding="5dp"
            android:drawableStart="@mipmap/union_rate_1_ic"
            android:layout_marginStart="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_rate_tip_2"
            app:layout_constraintTop_toBottomOf="@+id/tv_time_2"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_80FFF5AD"
            android:id="@+id/tv_rate_tip_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/union_diamond_rate_2"
            app:layout_constraintBottom_toBottomOf="@+id/tv_rate_2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tv_rate_2"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
