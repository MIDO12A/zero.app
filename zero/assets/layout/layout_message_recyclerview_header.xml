<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:layout_gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/idRlSystemNotification"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/idSystemNotification"
            android:layout_width="185dp"
            android:layout_height="70dp"
            android:src="@drawable/ic_system_notification"
            android:layout_marginEnd="13dp"/>
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text=" System \10 notification"
            android:layout_marginStart="30dp"/>
        <RelativeLayout
            android:background="@drawable/shape_msgcount_bg"
            android:layout_width="30dp"
            android:layout_height="20dp"
            android:layout_alignEnd="@+id/idSystemNotification">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:id="@+id/tvNotificationUnreadCount"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_centerInParent="true"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"/>
        </RelativeLayout>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/idRlEventInfomation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@+id/idRlSystemNotification">
        <ImageView
            android:layout_gravity="center_horizontal"
            android:id="@+id/idEventInformation"
            android:layout_width="185dp"
            android:layout_height="70dp"
            android:src="@drawable/ic_event_infomation"/>
        <TextView
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text=" Event \10 information"
            android:layout_marginStart="31dp"/>
        <RelativeLayout
            android:background="@drawable/shape_msgcount_bg"
            android:layout_width="30dp"
            android:layout_height="20dp"
            android:layout_alignEnd="@+id/idEventInformation">
            <TextView
                android:textSize="13sp"
                android:textColor="@color/white"
                android:id="@+id/tvInformationUnreadCount"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_centerInParent="true"
                android:paddingStart="3dp"
                android:paddingEnd="3dp"/>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
