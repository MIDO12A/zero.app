<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/shape_dialog"
    android:paddingTop="@dimen/dp_25"
    android:paddingBottom="@dimen/dp_25"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/dp_20"
    android:paddingStart="@dimen/dp_20"
    android:paddingEnd="@dimen/dp_20"
    android:layout_marginStart="@dimen/dp_60"
    android:layout_marginEnd="@dimen/dp_60">
    <TextView
        android:textSize="@dimen/sp_20"
        android:id="@+id/idTip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Tips"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/sp_17"
        android:id="@+id/idDeleteAccountSureTip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_10"
        android:text="@string/delete_account_sure_tip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idTip"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        app:layout_constraintTop_toBottomOf="@+id/idDeleteAccountSureTip">
        <TextView
            android:gravity="center"
            android:id="@+id/idCancle"
            android:background="@drawable/shape_gray"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_40"
            android:text="@string/Cancle"
            android:layout_marginStart="@dimen/dp_10"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.43"/>
        <TextView
            android:textSize="@dimen/dp_15"
            android:textColor="@color/color_894916"
            android:gravity="center"
            android:id="@+id/idDelete"
            android:background="@drawable/shapea"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_40"
            android:text="@string/Delete"
            android:layout_marginStart="@dimen/dp_10"
            android:layout_marginEnd="@dimen/dp_10"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.43"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
