<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/color_1A1A1A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top"
        android:background="@drawable/union_search_bg"
        android:paddingTop="44dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@mipmap/back_white_2"
            android:rotationY="@integer/locale_mirror_flip"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="20dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/tv_confirm"
        app:layout_constraintTop_toBottomOf="@+id/cl_top">
        <androidx.appcompat.widget.LinearLayoutCompat
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginHorizontal="16dp">
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/union_agency_information"
                android:drawablePadding="4dp"
                android:drawableStart="@mipmap/union_create_info_ic"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_img"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.yuehai.p١١٣ui.widget.roundimageview.RoundImageView
                    android:id="@+id/iv_union_img"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:layout_marginTop="40dp"
                    android:src="@mipmap/union_photo_ic"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:round_type="round"/>
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/iv_camera_ic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:src="@mipmap/common_camera_ic_2"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_union_img"
                    app:layout_constraintEnd_toEndOf="@+id/iv_union_img"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="14sp"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/union_agency_name"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:textSize="13sp"
                android:textColor="@color/color_FFFFFF"
                android:id="@+id/et_union_name"
                android:background="@drawable/union_et_shape_bg_12"
                android:paddingLeft="12dp"
                android:paddingTop="16dp"
                android:paddingRight="12dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:maxLines="1"
                android:maxLength="50"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp"/>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="14sp"
                android:textColor="@color/color_FFFFFF"
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/union_announcement"/>
            <androidx.appcompat.widget.AppCompatEditText
                android:textSize="13sp"
                android:textColor="@color/color_FFFFFF"
                android:textColorHint="@color/color_80ffffff"
                android:gravity="center_vertical"
                android:layout_gravity="start|top"
                android:id="@+id/et_union_announcement"
                android:background="@drawable/union_et_shape_bg_12"
                android:paddingLeft="12dp"
                android:paddingTop="16dp"
                android:paddingRight="12dp"
                android:paddingBottom="16dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="92dp"
                android:hint="@string/union_announcement_hint"
                android:maxLines="4"
                android:maxLength="400"
                android:paddingHorizontal="12dp"
                android:paddingVertical="16dp"/>
        </androidx.appcompat.widget.LinearLayoutCompat>
    </androidx.core.widget.NestedScrollView>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="@color/color_FF59370D"
        android:gravity="center"
        android:id="@+id/tv_confirm"
        android:background="@drawable/union_btn_pre_bg"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="28dp"
        android:text="@string/common_save"
        android:layout_marginHorizontal="16dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
