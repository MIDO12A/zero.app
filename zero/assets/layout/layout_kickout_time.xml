<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/black"
        android:id="@+id/idKickOutNow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_20"
        android:text="@string/kickoutNow"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/idDriver1"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/dp_18"
        android:alpha="0.1"
        app:layout_constraintTop_toBottomOf="@+id/idKickOutNow"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/black"
        android:id="@+id/idKickOutFor5m"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_15"
        android:text="@string/kickoutFor5m"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idDriver1"/>
    <View
        android:id="@+id/idDriver2"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/dp_18"
        android:alpha="0.1"
        app:layout_constraintTop_toBottomOf="@+id/idKickOutFor5m"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/black"
        android:id="@+id/idKickOutFor1h"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_15"
        android:text="@string/kickoutFor1h"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idDriver2"/>
    <View
        android:id="@+id/idDriver3"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="@dimen/dp_18"
        android:alpha="0.1"
        app:layout_constraintTop_toBottomOf="@+id/idKickOutFor1h"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/black"
        android:id="@+id/idKickOutFor24h"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_15"
        android:text="@string/kickoutFor24h"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idDriver3"/>
    <View
        android:id="@+id/idDriver4"
        android:background="@color/color_9BA1B6"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:layout_marginTop="@dimen/dp_25"
        android:alpha="0.1"
        app:layout_constraintTop_toBottomOf="@+id/idKickOutFor24h"/>
    <TextView
        android:textSize="@dimen/sp_16"
        android:textColor="@color/black"
        android:id="@+id/idCancel"
        android:paddingBottom="@dimen/dp_20"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_15"
        android:text="@string/cancel"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/idDriver4"/>
</androidx.constraintlayout.widget.ConstraintLayout>
