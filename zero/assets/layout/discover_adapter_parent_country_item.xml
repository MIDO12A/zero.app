<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/country_tab_layout"
        android:layout_width="0dp"
        android:layout_height="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/cl_more"
        app:layout_constraintTop_toTopOf="parent"
        app:tabBackground="@null"
        app:tabIndicatorHeight="0dp"
        app:tabMinWidth="66dp"
        app:tabMode="scrollable"
        app:tabPaddingBottom="4dp"
        app:tabPaddingEnd="8dp"
        app:tabPaddingStart="0dp"
        app:tabPaddingTop="4dp"
        app:tabRippleColor="@null"/>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:gravity="center"
        android:orientation="horizontal"
        android:id="@+id/cl_more"
        android:background="@drawable/discover_room_tab_more_bg"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_marginStart="16dp"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/country_tab_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/country_tab_layout">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btn_more"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@mipmap/discover_country_more_ic"
            android:rotationY="@integer/locale_mirror_flip"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="11sp"
            android:textColor="@color/color_FF59370D"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/country_name_more"
            android:layout_marginStart="2dp"
            app:layout_constraintWidth_max="60dp"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
    <include
        android:id="@+id/ll_header"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/country_tab_layout"
        layout="@layout/layout_head_discover_new"/>
    <com.yuehai.p١١٣ui.widget.viewpager.ChildViewPagerHost
        android:id="@+id/vp_country_host"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_header">
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_country_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </com.yuehai.p١١٣ui.widget.viewpager.ChildViewPagerHost>
</androidx.constraintlayout.widget.ConstraintLayout>
